@using QuanLyVatTu.Models
@model IEnumerable<VatTu>
@{
    ViewData["Title"] = "Danh Sách Hàng Hóa & Vật Tư";
    int? selectedDanhMucId = ViewBag.DanhMucId as int?;
    string tuKhoa = ViewBag.TuKhoa as string ?? string.Empty;
}

<link rel="stylesheet" href="~/css/dsvattu.css" asp-append-version="true" />

<div class="page-header">
    <h1 class="page-title">DANH SÁCH VẬT TƯ</h1>
    <div class="action-buttons">
        <button id="btnOpenAddModal" class="btn btn-primary" style="background:#2563eb"><i class="fa-solid fa-plus"></i> Thêm vật tư mới</button>
        <button class="btn btn-primary" href="/Home/BaoTri"
                style="background-color: white;border: 1px solid #cbd5e1; color: #475569;">
            <i class="fa-solid fa-file-excel"></i> Xuất Excel
        </button>
    </div>
</div>

<form class="filter-section" asp-controller="VatTu" asp-action="Index" method="get">
    <div class="filter-group">
        <label>Danh Mục</label>
        <select name="danhMucId">
            <option value="">Tất cả</option>
            @if (ViewBag.DanhMucs != null)
            {
                foreach (var dm in ViewBag.DanhMucs)
                {
                    <option value="@dm.Id" selected="@(selectedDanhMucId == dm.Id ? "selected" : null)">@dm.TenDanhMuc</option>
                }
            }
        </select>
    </div>
    <div class="filter-group" style="flex: 2;">
        <label>Tìm kiếm</label>
        <input type="text" name="tuKhoa" value="@tuKhoa" placeholder="Tìm theo mã hoặc tên vật tư...">
    </div>
    <button type="submit" class="btn-filter"><i class="fa-solid fa-filter"></i> Lọc</button>
</form>

<div class="table-container">
    <table class="data-table">
        <thead style="text-align: center;">
            <tr>
                <th>Mã vật tư</th>
                <th>Tên vật tư</th>
                <th>Danh mục</th>
                <th>Đơn vị tính</th>
                <th>Tồn kho hiện tại</th>
                <th>Giá vốn Bình quân</th>
                <th class="text-center">Hành động</th>
            </tr>
        </thead>
        <tbody id="vattuTableBody">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td style="text-align: center;">@item.MaVatTu</td>
                        <td style="font-weight: 500;">@item.TenVatTu</td>
                        <td>@(item.DanhMuc != null ? item.DanhMuc.TenDanhMuc : "Không xác định")</td>
                        <td style="text-align: center;">@item.DonViTinh</td>
                        <td style="text-align: center;">@item.TonKhoHienTai</td>
                        <td style="text-align: center;">@item.GiaVonBinhQuan.ToString("N0") VNĐ</td>
                        <td class="text-center" style="justify-content: center; gap: 10px; display: flex;">
                            <button class="btn btn-sm btn-primary btn-edit" data-id="@item.Id" style="background: green;"><i class="fa-solid fa-pen-to-square"></i> Sửa</button>
                            <button class="btn btn-sm btn-danger btn-delete" data-id="@item.Id" style="background: red;"><i class="fa-solid fa-trash"></i> Xóa</button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">Không có dữ liệu vật tư.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="addModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fa-solid fa-box-open" style="color:#1a2d42; margin-right:8px;"></i> THÊM VẬT TƯ MỚI</h3>
            <button id="btnCloseModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="inputId" value="0">

            <div class="input-row">
                <div class="filter-group">
                    <label>Mã vật tư <span style="color:red">*</span></label>
                    <input type="text" id="inputMaVatTu" placeholder="Nhập mã...">
                </div>
                <div class="filter-group">
                    <label>Danh mục</label>
                    <select id="inputDanhMucId">
                        @if (ViewBag.DanhMucs != null)
                        {
                            foreach (var dm in ViewBag.DanhMucs)
                            {
                                <option value="@dm.Id">@dm.TenDanhMuc</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div class="filter-group">
                <label>Tên vật tư <span style="color:red">*</span></label>
                <input type="text" id="inputTenVatTu" placeholder="Nhập tên vật tư...">
            </div>

            <div class="input-row">
                <div class="filter-group">
                    <label>Đơn vị tính</label>
                    <input type="text" id="inputDonViTinh" placeholder="VD: Bao, Thùng...">
                </div>
                <div class="filter-group">
                    <label>Tồn kho</label>
                    <input type="number" id="inputTonKhoHienTai" value="0">
                </div>
            </div>

            <div class="filter-group">
                <label>Tồn kho tối thiểu</label>
                <input type="number" id="inputTonToiThieu" value="0">
            </div>
        </div>

        <div class="modal-footer">
            <button id="btnCancel" class="btn btn-cancel">Hủy Bỏ</button>
            <button id="btnSave" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu Vật Tư</button>
        </div>
    </div>
</div>

<script src="~/js/dsvattu.js" asp-append-version="true"></script>
