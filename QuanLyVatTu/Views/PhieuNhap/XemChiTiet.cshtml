@model QuanLyVatTu.Models.PhieuNhap
@using System.Globalization

@{
    ViewData["Title"] = "Chi Tiết Phiếu Nhập Kho";
    bool isReadOnly = true;
}

<link rel="stylesheet" href="~/css/ctNhap.css" asp-append-version="true" />
<body data-readonly="true">
    <div class="page-header">
        <div style="display: flex; align-items: center; gap: 15px;">
            <a asp-controller="PhieuNhap" asp-action="PhieuNhap" class="btn btn-secondary" title="Quay lại" style="text-decoration: none;">
                <i class="fa-solid fa-arrow-left"></i>
            </a>
            <h1 class="page-title">Chi tiết phiếu nhập</h1>
        </div>
        <div style="display: flex; gap: 10px;">
            <button class="btn btn-secondary" onclick="window.print();"><i class="fa-solid fa-print"></i> In phiếu</button>

            @* Hiển thị nút Duyệt / Từ chối nếu phiếu chưa duyệt và user có quyền (Authorize ở controller) *@
            @if (Model.TrangThai != QuanLyVatTu.Models.TrangThaiPhieuNhap.DaDuyet)
            {
                <form asp-action="DuyetPhieuNhap" asp-controller="PhieuNhap" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-success"><i class="fa-solid fa-check"></i> Hoàn tất phiếu</button>
                </form>

                <form asp-action="TuChoiPhieuNhap" asp-controller="PhieuNhap" method="post" style="display:inline; margin-left:8px" onsubmit="return confirm('Bạn có chắc muốn từ chối phiếu này?');">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="lyDo" value="Từ chối bởi người dùng" />
                    <button type="submit" class="btn btn-warning"><i class="fa-solid fa-ban"></i> Từ chối phiếu</button>
                </form>
            }
            else
            {
                <span class="badge bg-success" style="align-self:center">Đã duyệt</span>
            }
        </div>
    </div>

    <div class="section-card">
        <div class="section-title"><i class="fa-solid fa-circle-info" style="color:#3b82f6;"></i> THÔNG TIN PHIẾU NHẬP</div>
        <div class="input-row">
            <input type="hidden" id="hdfPhieuNhapId" value="@Model.Id" />
            <input type="hidden" id="hdfNgayNhap" value="@Model.NgayNhap.ToString("dd/MM/yyyy HH:mm", CultureInfo.InvariantCulture)" />
            <input type="hidden" id="hdfKhoId" value="@Model.KhoId" />
            <input type="hidden" id="hdfNhaCungCapId" value="@Model.NhaCungCapId" />
            <input type="hidden" id="hdfGhiChu" value="@Model.GhiChu" />

            <div class="form-group">
                <label>Mã phiếu</label>
                <div class="form-control" style="background-color: #f8fafc; border: 1px solid #e5e7eb; padding: 8px;">
                    <strong>@Model.MaPhieu</strong>
                </div>
            </div>

            <div class="form-group">
                <label>Ngày nhập</label>
                <div class="form-control" style="background-color: #f8fafc; border: 1px solid #e5e7eb; padding: 8px;">
                    @Model.NgayNhap.ToString("dd/MM/yyyy HH:mm")</div>
            </div>

            <div class="form-group">
                <label>Kho Nhập</label>
                <div class="form-control" style="background-color: #f8fafc; border: 1px solid #e5e7eb; padding: 8px;">
                    @Model.Kho?.TenKho</div>
            </div>

            <div class="form-group">
                <label>Nhà cung cấp</label>
                <div class="form-control" style="background-color: #f8fafc; border: 1px solid #e5e7eb; padding: 8px;">
                    @Model.NhaCungCap?.TenNhaCungCap</div>
            </div>
        </div>
    </div>

    @* Không hiển thị khu vực thêm vật tư — chỉ danh sách theo MaPhieu *@
    <div class="section-card">
        <div class="section-title"><i class="fa-solid fa-list" style="color:#64748b;"></i> DANH SÁCH MẶT HÀNG NHẬP</div>
        <div class="table-container">
            <table class="data-table" id="bangChiTiet">
                <thead>
                    <tr>
                        <th class="text-center" style="width: 50px;">STT</th>
                        <th class="text-center">Mã vật tư</th>
                        <th class="text-center">Tên vật tư</th>
                        <th class="text-center">ĐVT</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-center">Đơn giá</th>
                        <th class="text-center">Thành tiền</th>
                    </tr>
                </thead>

                <tbody id="chiTietBody">
                    @if (Model.ChiTietPhieuNhaps != null && Model.ChiTietPhieuNhaps.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model.ChiTietPhieuNhaps)
                        {
                            <tr>
                                <td class="text-center">@(stt++)</td>
                                <td class="td-vattu text-center">@item.VatTu?.MaVatTu ?? item.MaVatTu</td>
                                <td class="td-vattu">@item.VatTu?.TenVatTu ?? item.TenVatTu</td>
                                <td class="text-center">@item.VatTu?.DonViTinh ?? item.DonVi</td>
                                <td class="text-center">@item.SoLuong.ToString("N0")</td>
                                <td class="text-center">@item.DonGia.ToString("N0") ₫</td>
                                <td class="text-center" style="font-weight:700; color:#e11d48;">@item.ThanhTien.ToString("N0") ₫</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr id="emptyRow">
                            <td colspan="7" class="text-center" style="color: #94a3b8; font-style: italic; padding: 30px;">
                                Chưa có vật tư nào trong phiếu.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="summary-section">
            <div class="summary-box">
                <div class="summary-line">
                    <span>Tổng số mặt hàng:</span>
                    <span style="font-weight:600; color:#0f172a;">@(Model.ChiTietPhieuNhaps?.Count() ?? 0)</span>
                </div>
                <div class="summary-line">
                    <span>Tổng số lượng:</span>
                    <span style="font-weight:600; color:#0f172a;">@(Model.ChiTietPhieuNhaps?.Sum(x => x.SoLuong) ?? 0)</span>
                </div>
                <div class="summary-total">
                    <span>TỔNG TIỀN:</span>
                    <span>@((Model.ChiTietPhieuNhaps?.Sum(x => x.ThanhTien) ?? 0).ToString("N0")) đ</span>
                </div>
            </div>
        </div>
    </div>

    <script>
            (function(){
                try {
                    // Tên action hoặc phần URL cần giữ enabled
                    const keepActions = ['DuyetPhieuNhap', 'TuChoiPhieuNhap'];

                    document.querySelectorAll('button, input, select, textarea').forEach(function(el){
                        // Nếu element nằm trong form
                        const form = el.closest('form');
                        if (form) {
                            // Lấy action thực tế (Razor render thành attribute "action")
                            const action = form.getAttribute('action') || '';
                            const shouldKeep = keepActions.some(k => action.includes(k));
                            if (shouldKeep) return;
                            // Nếu form có class keep-enabled thì giữ nguyên
                            if (form.classList && form.classList.contains('keep-enabled')) return;
                        }

                        // Nếu chính element có attribute data-keep-enabled thì giữ nguyên
                        if (el.hasAttribute('data-keep-enabled')) return;

                        // Không disable các nút submit trong form có method post và action rỗng (trường hợp đặc biệt)
                        // (bỏ qua nếu bạn muốn disable tất cả)
                        el.setAttribute('disabled', 'disabled');
                    });
                } catch (e) {
                    console.error('Disable script error:', e);
                }
            })();
    </script>
</body>
