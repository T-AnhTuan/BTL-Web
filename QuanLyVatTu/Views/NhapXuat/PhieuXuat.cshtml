@{
    ViewData["Title"] = "Quản Lý Phiếu Xuất Kho";
}

<link rel="stylesheet" href="~/css/xuat.css" asp-append-version="true" />

<h1 class="page-title">Quản lý xuất kho</h1>

<div class="toolbar-section">
    <div class="search-box-container">
        <input type="text" placeholder="Tìm kiếm nhanh (ví dụ: mã phiếu...)">
        <i class="fa-solid fa-magnifying-glass"></i>
    </div>
    <button id="btnOpenModal" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Tạo Phiếu Xuất Mới</button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>Mã Phiếu</th>
                <th>Ngày Xuất</th>
                <th>Khách Hàng / Công Trình</th>
                <th>Người Xuất</th>
                <th>Lý Do Xuất</th>
                <th class="text-right">Tổng Tiền (VNĐ)</th>
                <th class="text-center">Trạng Thái</th>
                <th class="text-center">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
        </tbody>
    </table>
</div>

<div id="addExportModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fa-solid fa-file-export" style="color:#2563eb; margin-right:8px;"></i> TẠO PHIẾU XUẤT MỚI</h3>
            <button id="btnCloseModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="inputId" value="0">

            <div class="input-row">
                <div class="form-group">
                    <label>Mã Phiếu Xuất (Hệ thống tự sinh nếu để trống)</label>
                    <input type="text" placeholder="VD: PX-2026-001">
                </div>
                <div class="form-group">
                    <label>Ngày Xuất <span style="color:red">*</span></label>
                    <input type="date">
                </div>
            </div>

            <div class="input-row">
                <div class="form-group">
                    <label>Khách Hàng / Công Trình <span style="color:red">*</span></label>
                    <input type="text" placeholder="Nhập tên khách hàng hoặc công trình...">
                </div>
                <div class="form-group">
                    <label>Người Xuất</label>
                    <input type="text" placeholder="Tên người phụ trách xuất kho..." value="">
                </div>
            </div>

            <div class="form-group">
                <label>Lý Do Xuất</label>
                <textarea rows="2" placeholder="Nhập lý do xuất kho (ví dụ: xuất thi công công trình A, xuất bán...)"></textarea>
            </div>

            <div style="background: #eff6ff; padding: 10px; border-radius: 6px; color: #1e40af; font-size: 13px;">
                <i class="fa-solid fa-circle-info"></i> Sau khi lưu thông tin chung, hệ thống sẽ chuyển sang giao diện để bạn chọn vật tư cần xuất.
            </div>
        </div>

        <div class="modal-footer">
            <button id="btnCancel" class="btn btn-cancel">Hủy Bỏ</button>
            <button id="btnSave" class="btn btn-primary"><i class="fa-solid fa-arrow-right"></i> Tiếp Tục Chọn Vật Tư</button>
        </div>
    </div>
</div>

<script src="~/js/xuat.js" asp-append-version="true">
    
</script>