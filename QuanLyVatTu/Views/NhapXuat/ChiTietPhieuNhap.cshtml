@model QuanLyVatTu.Models.PhieuNhap
@{
    ViewData["Title"] = "Chi Tiết Phiếu Nhập Kho";
}

<link rel="stylesheet" href="~/css/ctNhap.css" asp-append-version="true"/>

<div class="page-header">
    <div style="display: flex; align-items: center; gap: 15px;">
        <a asp-controller="NhapXuat" asp-action="PhieuNhap" class="btn btn-secondary" title="Quay lại" style="text-decoration: none;"><i class="fa-solid fa-arrow-left"></i></a>
        <h1 class="page-title">Chi tiết phiếu nhập</h1>
    </div>
    <div style="display: flex; gap: 10px;">
        <button class="btn btn-secondary"><i class="fa-solid fa-print"></i> In Phiếu (Nháp)</button>
        <button class="btn btn-success" onclick="hoanTatPhieu()"><i class="fa-solid fa-check"></i> Hoàn Tất Lưu Phiếu</button>
    </div>
</div>

<div class="section-card">
    <div class="section-title"><i class="fa-solid fa-circle-info" style="color:#3b82f6;"></i> THÔNG TIN PHIẾU NHẬP</div>
    <div class="input-row">
        <div class="form-group">
            <label>Mã phiếu</label>
            <input @Model.MaPhieu readonly>
        </div>
        <div class="form-group">
            <label>Ngày nhập</label>
            <input @Model.NgayNhap.ToString("dd/MM/yyyy HH:mm") readonly>
        </div>
        <div class="form-group">
            <label>Nhà cung cấp</label>
            <input @Model.NhaCungCap?.TenNhaCungCap readonly>
        </div>
        <div class="form-group">
            <label>Kho nhập</label>
            <input @Model.Kho?.TenKho" readonly>
        </div>
    </div>
</div>

<div class="section-card" style="background-color: #f8fafc; border-style: dashed; border-color: #94a3b8;">
    <div class="section-title"><i class="fa-solid fa-cart-plus" style="color:#10b981;"></i> THÊM VẬT TƯ VÀO PHIẾU</div>
    <div class="input-row" style="align-items: flex-end;">
        <div class="form-group" style="flex: 2;">
            <label>Chọn vật tư <span style="color:red">*</span></label>
            <select id="cboVatTu" class="form-control">
                <option value="">-- Vui lòng chọn vật tư --</option>
                @if (ViewBag.VatTus != null)
                {
                    foreach (var vt in ViewBag.VatTus)
                    {
                        <option value="@vt.Id" data-dvt="@vt.DonViTinh">
                            [@vt.MaVatTu] - @vt.TenVatTu
                        </option>
                    }
                }
            </select>
        </div>
        <div class="form-group" style="flex: 0.5;">
            <label>Số Lượng <span style="color:red">*</span></label>
            <input type="number" id="txtSoLuong" value="1" min="1">
        </div>
        <div class="form-group" style="flex: 1;">
            <label>Đơn Giá Nhập (VNĐ) <span style="color:red">*</span></label>
            <input type="number" id="txtDonGia" value="0" min="0">
        </div>
        <div class="form-group" style="flex: 0;">
            <button class="btn btn-primary" onclick="themVatTuVaoBang()"><i class="fa-solid fa-arrow-down"></i> Thêm Xuống Lưới</button>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-title"><i class="fa-solid fa-list" style="color:#64748b;"></i> DANH SÁCH MẶT HÀNG NHẬP</div>
    <div class="table-container">
        <table class="data-table" id="bangChiTiet">
            <thead>
                <tr>
                    <th class="text-center" style="width: 50px;">STT</th>
                    <th>Mã VT</th>
                    <th>Tên Vật Tư</th>
                    <th class="text-center">ĐVT</th>
                    <th class="text-right">Số Lượng</th>
                    <th class="text-right">Đơn Giá Nhập</th>
                    <th class="text-right">Thành Tiền</th>
                    <th class="text-center" style="width: 60px;">Xóa</th>
                </tr>
            </thead>
            <input type="hidden" id="hdfPhieuNhapId" value="@Model.Id" />

            <tbody id="chiTietBody">
                @if (Model.ChiTietPhieuNhaps != null && Model.ChiTietPhieuNhaps.Any())
                {
                    foreach (var item in Model.ChiTietPhieuNhaps)
                    {
                        <tr>
                            <td class="text-center">@item.VatTu?.MaVatTu</td>
                            <td>@item.VatTu?.TenVatTu</td>
                            <td class="text-center">@item.VatTu?.DonViTinh</td>
                            <td class="text-right num-soluong">@item.SoLuong.ToString("N0")</td>
                            <td class="text-right">@item.DonGia.ToString("N0") ₫</td>
                            <td class="text-right num-thanhtien" data-value="@item.ThanhTien" style="font-weight: 700; color: #e11d48;">
                                @item.ThanhTien.ToString("N0") ₫
                            </td>
                            <td class="text-center">
                                <!-- Nút Xóa lưu giữ data-id để gửi cho Javascript -->
                                <button class="btn btn-danger btn-delete-row" data-id="@item.Id" style="padding: 6px 10px;">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr id="emptyRow">
                        <td colspan="7" class="text-center" style="color: #94a3b8; font-style: italic; padding: 30px;">
                            Chưa có vật tư nào trong phiếu. Vui lòng chọn vật tư và thêm xuống lưới!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="summary-section">
        <div class="summary-box">
            <div class="summary-line">
                <span>Tổng số mặt hàng:</span>
                <span id="lblTongMatHang" style="font-weight: 600; color: #0f172a;">0</span>
            </div>
            <div class="summary-line">
                <span>Tổng số lượng:</span>
                <span id="lblTongSoLuong" style="font-weight: 600; color: #0f172a;">0</span>
            </div>
            <div class="summary-total">
                <span>TỔNG TIỀN:</span>
                <span id="lblTongTien">0 đ</span>
            </div>
        </div>
    </div>
</div>

<script src="~/js/ctNhap.js" asp-append-version="true">
</script>