@using QuanLyVatTu.Models
@model IEnumerable<QuanLyVatTu.Models.PhieuNhap>
@{
    ViewData["Title"] = "Quản Lý Phiếu Nhập";
}

<link rel="stylesheet" href="~/css/nhap.css" asp-append-version="true" />

<h1 class="page-title">Quản lý Nhập kho</h1>

<!-- Hiển thị thông báo (nếu có) -->
@if (TempData["SuccessMsg"] != null)
{
    <div style="padding:15px; margin-bottom: 20px; background-color: #dcfce3; color: #166534; border-radius: 8px;">
        <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMsg"]
    </div>
}
@if (TempData["ErrorMsg"] != null)
{
    <div style="padding:15px; margin-bottom: 20px; background-color: #fee2e2; color: #991b1b; border-radius: 8px;">
        <i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMsg"]
    </div>
}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <h4>Tổng Phiếu Nhập</h4>
            <div class="value">@(Model != null ? Model.Count() : 0)</div>
        </div>
        <div class="stat-icon icon-blue"><i class="fa-solid fa-file-lines"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h4>Giá Trị Nhập Tháng Này</h4>
            <div class="value">
                @(Model != null ? Model.Where(m => m.NgayNhap.Month == DateTime.Now.Month).Sum(m => m.TongGiaTri).ToString("N0") : "0") VNĐ
            </div>
        </div>
        <div class="stat-icon icon-green"><i class="fa-solid fa-credit-card"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h4>Phiếu Chờ Duyệt</h4>
            <div class="value">@(Model != null ? Model.Count(m => m.TrangThai == TrangThaiPhieuNhap.ChoDuyet) : 0)</div>
        </div>
        <div class="stat-icon icon-orange"><i class="fa-regular fa-clock"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h4>Trạng Thái</h4>
            <div class="value" style="font-size: 18px; color: #64748b;">Đang hoạt động</div>
        </div>
        <div class="stat-icon icon-emerald"><i class="fa-solid fa-layer-group"></i></div>
    </div>
</div>

<div class="filter-section">
    <div class="filter-group search-box-container">
        <label>Tìm kiếm</label>
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Tìm kiếm mã phiếu, nhà cung cấp...">
    </div>
    <div class="filter-group">
        <label>Nhà Cung Cấp</label>
        <select>
            <option value="">-- Tất cả nhà cung cấp --</option>
            @if (ViewBag.NhaCungCaps != null)
            {
                foreach (var ncc in ViewBag.NhaCungCaps)
                {
                    <option value="@ncc.Id">@ncc.TenNhaCungCap</option>
                }
            }
        </select>
    </div>
    <div class="filter-group">
        <label>Trạng Thái</label>
        <select>
            <option value="">Tất cả</option>
            <option value="1">Đã Duyệt</option>
            <option value="0">Chờ Duyệt</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Khoảng Thời Gian</label>
        <input type="date" placeholder="Từ ngày - Đến ngày">
    </div>
</div>

<div class="table-toolbar">
    <button id="btnOpenModal" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Tạo Phiếu Nhập Mới</button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 40px;"><input type="checkbox"></th>
                <th>Mã Phiếu</th>
                <th>Ngày Nhập</th>
                <th>Nhà Cung Cấp</th>
                <th>Kho Nhập</th>
                <th class="text-center">Số Dòng</th>
                <th class="text-right">Tổng Giá Trị (VNĐ)</th>
                <th class="text-center">Trạng Thái</th>
                <th class="text-center">Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td><input type="checkbox" value="@item.Id"></td>
                        <td style="font-weight: 600; color: #2563eb;">@item.MaPhieu</td>
                        <td>@item.NgayNhap.ToString("dd/MM/yyyy")</td>
                        <td>@(item.NhaCungCap != null ? item.NhaCungCap.TenNhaCungCap : "N/A")</td>
                        <td>@(item.Kho != null ? item.Kho.TenKho : "N/A")</td>
                        <td class="text-center">@(item.ChiTietPhieuNhaps != null ? item.ChiTietPhieuNhaps.Count : 0)</td>
                        <td class="text-right" style="font-weight: 600; color: #059669;">@item.TongGiaTri.ToString("N0")</td>
                        <td class="text-center">
                            @if (item.TrangThai == TrangThaiPhieuNhap.DaDuyet)
                            {
                                <span style="background: #dcfce3; color: #166534; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Đã Duyệt</span>
                            }
                            else if (item.TrangThai == TrangThaiPhieuNhap.ChoDuyet)
                            {
                                <span style="background: #fef08a; color: #854d0e; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Chờ Duyệt</span>
                            }
                            else
                            {
                                <span style="background: #fee2e2; color: #991b1b; padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;">Từ Chối</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="btn btn-sm" style="background: #eff6ff; color: #2563eb; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer;" title="Xem chi tiết"><i class="fa-solid fa-eye"></i></button>
                            @if (item.TrangThai == TrangThaiPhieuNhap.ChoDuyet)
                            {
                                <form asp-action="DuyetPhieuNhap" asp-controller="NhapXuat" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm" style="background: #dcfce3; color: #166534; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-left: 5px;" title="Duyệt phiếu nhập" onclick="return confirm('Bạn có chắc muốn duyệt phiếu nhập này? Hệ thống sẽ cập nhật tồn kho và giá vốn.');">
                                        <i class="fa-solid fa-check"></i>
                                    </button>
                                </form>
                                <form asp-action="HuyPhieuNhap" asp-controller="NhapXuat" method="post" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm" style="background: #fee2e2; color: #991b1b; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; margin-left: 5px;" title="Hủy phiếu nhập" onclick="return confirm('Bạn có chắc muốn hủy phiếu nhập này?');">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center" style="padding: 30px; color: #64748b;">Chưa có dữ liệu phiếu nhập kho nào.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Modal Bọc bằng Form chuẩn MVC -->
<div id="addReceiptModal" class="modal-overlay">
    <div class="modal-box">
        <form asp-action="TaoPhieuNhap" asp-controller="NhapXuat" method="post">
            <div class="modal-header">
                <h3><i class="fa-solid fa-file-circle-plus" style="color:#2563eb; margin-right:8px;"></i> TẠO PHIẾU NHẬP MỚI</h3>
                <button type="button" id="btnCloseModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
            </div>

            <div class="modal-body">
                <div class="input-row">
                    <div class="filter-group">
                        <label>Mã Phiếu (Hệ thống tự sinh nếu để trống)</label>
                        <input type="text" name="MaPhieu" placeholder="VD: PN-00123">
                    </div>
                    <div class="filter-group">
                        <label>Ngày Nhập <span style="color:red">*</span></label>
                        <input type="date" name="NgayNhap" required value="@DateTime.Now.ToString("yyyy-MM-dd")">
                    </div>
                </div>

                <div class="input-row">
                    <div class="filter-group">
                        <label>Nhà Cung Cấp <span style="color:red">*</span></label>
                        <select name="NhaCungCapId" required>
                            <option value="">-- Chọn nhà cung cấp --</option>
                            @if (ViewBag.NhaCungCaps != null)
                            {
                                foreach (var ncc in ViewBag.NhaCungCaps)
                                {
                                    <option value="@ncc.Id">@ncc.TenNhaCungCap</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="filter-group">
                        <label>Kho Nhập <span style="color:red">*</span></label>
                        <select name="KhoId" required>
                            <option value="">-- Chọn kho nhập --</option>
                            @if (ViewBag.Khos != null)
                            {
                                foreach (var kho in ViewBag.Khos)
                                {
                                    <option value="@kho.Id">@kho.TenKho</option>
                                }
                            }
                        </select>
                    </div>
                </div>

                <div class="filter-group">
                    <label>Ghi Chú</label>
                    <textarea name="GhiChu" rows="2" style="padding: 10px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; font-family: inherit;" placeholder="Nhập ghi chú cho phiếu nhập này..."></textarea>
                </div>

                <div style="background: #eff6ff; padding: 10px; border-radius: 6px; color: #1e40af; font-size: 13px; margin-top: 15px;">
                    <i class="fa-solid fa-circle-info"></i> Sau khi lưu thông tin chung (Header), hệ thống sẽ chuyển sang trang chi tiết để bạn thêm vật tư vào phiếu nhập.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" id="btnCancel" class="btn btn-cancel">Hủy Bỏ</button>
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-arrow-right"></i> Tiếp Tục Thêm Vật Tư</button>
            </div>
        </form>
    </div>
</div>

<script src="~/js/nhap.js" asp-append-version="true"></script>
