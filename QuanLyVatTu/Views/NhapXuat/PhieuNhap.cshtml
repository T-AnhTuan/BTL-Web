@{
    ViewData["Title"] = "Quản Lý Phiếu Nhập";
}

<link rel="stylesheet" href="~/css/nhap.css" asp-append-version="true" />

<h1 class="page-title">Quản lý Nhập kho</h1>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <h4>Tổng Phiếu Nhập</h4>
            <div class="value">0</div>
        </div>
        <div class="stat-icon icon-blue"><i class="fa-solid fa-file-lines"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h4>Giá Trị Nhập Tháng Này</h4>
            <div class="value">0 VNĐ</div>
        </div>
        <div class="stat-icon icon-green"><i class="fa-solid fa-credit-card"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h4>Phiếu Chờ Duyệt</h4>
            <div class="value">0</div>
        </div>
        <div class="stat-icon icon-orange"><i class="fa-regular fa-clock"></i></div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <h4>Vật Tư Nhập</h4>
            <div class="value">0 <span style="font-size: 14px; font-weight: 500; color: #64748b;">mặt hàng</span></div>
        </div>
        <div class="stat-icon icon-emerald"><i class="fa-solid fa-layer-group"></i></div>
    </div>
</div>

<div class="filter-section">
    <div class="filter-group search-box-container">
        <label>Tìm kiếm</label>
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" placeholder="Tìm kiếm mã phiếu, nhà cung cấp...">
    </div>
    <div class="filter-group">
        <label>Nhà Cung Cấp</label>
        <select><option value="">-- Chọn nhà cung cấp --</option></select>
    </div>
    <div class="filter-group">
        <label>Kho Nhập</label>
        <select><option value="">-- Chọn kho --</option></select>
    </div>
    <div class="filter-group">
        <label>Trạng Thái</label>
        <select>
            <option value="">Tất cả</option>
            <option value="HoanThanh">Đã Hoàn Thành</option>
            <option value="ChoDuyet">Chờ Duyệt</option>
            <option value="DaHuy">Đã Hủy</option>
        </select>
    </div>
    <div class="filter-group">
        <label>Khoảng Thời Gian</label>
        <input type="date" placeholder="Từ ngày - Đến ngày">
    </div>
</div>

<div class="table-toolbar">
    <button id="btnOpenModal" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Tạo Phiếu Nhập Mới</button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 40px;"><input type="checkbox"></th>
                <th>STT</th>
                <th>Mã Phiếu</th>
                <th>Ngày Nhập</th>
                <th>Nhà Cung Cấp</th>
                <th>Kho Nhập</th>
                <th class="text-center">Số Dòng</th>
                <th class="text-right">Tổng Giá Trị (VNĐ)</th>
                <th class="text-center">Trạng Thái</th>
                <th class="text-center">Hành Động</th>
            </tr>
        </thead>
        <tbody>
        </tbody>
    </table>
</div>

<div id="addReceiptModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fa-solid fa-file-circle-plus" style="color:#2563eb; margin-right:8px;"></i> TẠO PHIẾU NHẬP MỚI</h3>
            <button id="btnCloseModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
            <div class="input-row">
                <div class="filter-group">
                    <label>Mã Phiếu (Hệ thống tự sinh nếu để trống)</label>
                    <input type="text" placeholder="VD: PN-00123">
                </div>
                <div class="filter-group">
                    <label>Ngày Nhập <span style="color:red">*</span></label>
                    <input type="date">
                </div>
            </div>

            <div class="input-row">
                <div class="filter-group">
                    <label>Nhà Cung Cấp <span style="color:red">*</span></label>
                    <select><option value="">-- Chọn nhà cung cấp --</option></select>
                </div>
                <div class="filter-group">
                    <label>Kho Nhập <span style="color:red">*</span></label>
                    <select><option value="">-- Chọn kho nhập --</option></select>
                </div>
            </div>

            <div class="filter-group">
                <label>Ghi Chú</label>
                <textarea rows="2" style="padding: 10px; border: 1px solid #e2e8f0; border-radius: 6px; outline: none; font-family: inherit;" placeholder="Nhập ghi chú cho phiếu nhập này..."></textarea>
            </div>

            <div style="background: #eff6ff; padding: 10px; border-radius: 6px; color: #1e40af; font-size: 13px;">
                <i class="fa-solid fa-circle-info"></i> Sau khi lưu thông tin chung (Header), hệ thống sẽ chuyển sang trang chi tiết để bạn thêm vật tư vào phiếu nhập.
            </div>
        </div>

        <div class="modal-footer">
            <button id="btnCancel" class="btn btn-cancel">Hủy Bỏ</button>
            <button id="btnSave" class="btn btn-primary"><i class="fa-solid fa-arrow-right"></i> Tiếp Tục Thêm Vật Tư</button>
        </div>
    </div>
</div>

<script src="~/js/nhap.js" asp-append-version="true">
    
</script>