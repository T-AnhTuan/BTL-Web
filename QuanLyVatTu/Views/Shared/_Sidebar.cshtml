<!-- Lấy tên Controller hiện tại đang chạy để làm hiệu ứng sáng màu (Active) cho Menu -->
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!-- 1. PHẦN LOGO TRÊN CÙNG -->
<div class="sidebar-logo">
    <!-- Bạn có thể thay icon bằng thẻ <img src="..."> nếu có logo ảnh thật -->
    <i class="fas fa-cubes fa-2x text-info mb-2"></i>
    <h4 class="sidebar-title">KHO VẬT TƯ</h4>
</div>

<!-- 2. PHẦN THÔNG TIN NGƯỜI ĐĂNG NHẬP -->
<div class="sidebar-user">
    <!-- Avatar mặc định -->
    <img src="https://cdn-icons-png.flaticon.com/512/3135/3135715.png" alt="Avatar" class="rounded-circle me-3" style="width: 40px; height: 40px;">
    <div>
        <!-- Kiểm tra xem có người đang đăng nhập không, nếu có in tên ra -->
        <h6 class="sidebar-username">@(User.Identity.IsAuthenticated ? User.Identity.Name : "Khách")</h6>
        <!-- Hiện nút trạng thái Online màu xanh lá -->
        <small class="sidebar-status"><i class="fas fa-circle" style="font-size: 8px;"></i> Đang hoạt động</small>
    </div>
</div>

<!-- 3. PHẦN CÁC NÚT MENU CHỨC NĂNG LỚN -->
<div class="sidebar-content">
    <ul class="sidebar-menu">
        <!-- Nút Trang chủ: So sánh nếu Controller hiện tại là 'Home' thì gắn class 'active' -->
        <li>
            <a href="/Home/Index" class="@(currentController == "Home" ? "active" : "")">
                <i class="fas fa-tachometer-alt"></i> Trang Tổng Quan
            </a>
        </li>

        <!-- Nút Quản lý Nhập Xuất -->
        <li>
            <a href="/NhapXuat/Index" class="@(currentController == "NhapXuat" ? "active" : "")">
                <i class="fas fa-exchange-alt"></i> Quản Lý Nhập / Xuất
            </a>
        </li>

        <!-- Nút Quản lý Báo cáo -->
        <li>
            <a href="/BaoCao/Index" class="@(currentController == "BaoCao" ? "active" : "")">
                <i class="fas fa-chart-pie"></i> Báo Cáo & Thống Kê
            </a>
        </li>

        <!-- Nút Quản lý Hệ thống (Chỉ hiện nếu user đăng nhập có quyền Admin) -->
        @if (User.IsInRole("Admin"))
        {
            <li>
                <a href="/NguoiDung/DanhSachTaiKhoan" class="@(currentController == "NguoiDung" ? "active" : "")">
                    <i class="fas fa-users-cog"></i> Quản Lý Hệ Thống
                </a>
            </li>
        }
    </ul>
</div>