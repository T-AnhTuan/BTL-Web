@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject QuanLyVatTu.Data.AppDbContext _context
@{
    // 1. Lấy Tên đăng nhập (Username) từ Cookie. Cái này không bao giờ đổi nên lấy từ Cookie là an toàn.
    var currentUsername = User.Identity?.Name;

    // 2. Gán giá trị mặc định ban đầu nếu người dùng chưa đăng nhập
    var fullName = "Khách";
    var roleName = "Chưa phân quyền";

    // 3. Kiểm tra xem nếu đã đăng nhập thì móc dữ liệu MỚI NHẤT từ CSDL ra
    if (!string.IsNullOrEmpty(currentUsername))
    {
        // Truy vấn bảng TaiKhoan, nối (Include) bảng NhanVien và VaiTro để lấy Tên và Quyền mới nhất
        var userInDb = _context.TaiKhoans
            .Include(t => t.NhanVien)
            .Include(t => t.VaiTro)
            .FirstOrDefault(t => t.TenDangNhap == currentUsername);

        // Nếu tìm thấy tài khoản trong CSDL
        if (userInDb != null)
        {
            // Lấy Họ tên mới nhất từ bảng NhanVien. Nếu không có (null) thì lấy Tên đăng nhập làm tạm.
            fullName = userInDb.NhanVien?.HoTen ?? currentUsername;

            // Lấy Tên vai trò mới nhất từ bảng VaiTro
            roleName = userInDb.VaiTro?.TenVaiTro ?? "Chưa phân quyền";
        }
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản lý Vật tư</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-brand">
            <i class="fa-solid fa-warehouse"></i> VẬT TƯ & TỒN KHO
        </div>
        <div class="sidebar-user">
            <i class="fa-solid fa-circle-user" style="font-size: 38px; color: #cbd5e1;"></i>
            <div>
                <div class="user-name">@fullName</div>
                <div class="user-role">@roleName</div>
            </div>
        </div>
        <div class="sidebar-menu">
            <ul>
                <li><a asp-controller="Home" asp-action="Index"><i class="fa-solid fa-gauge"></i> Trang chủ</a></li>

                <div class="menu-category">Quản lý danh mục</div>
                <li><a asp-controller="VatTu" asp-action="Index"><i class="fa-solid fa-box"></i> Vật tư</a></li>
                <li><a asp-controller="DanhMuc" asp-action="VatTu"><i class="fa-solid fa-list"></i> Danh mục vật tư</a></li>
                <li><a href="/Home/BaoTri"><i class="fa-solid fa-list"></i> Danh mục kho</a></li>
                <li><a asp-controller="DanhMuc" asp-action="NhaCungCap"><i class="fa-solid fa-industry"></i> Nhà cung cấp</a></li>

                <div class="menu-category">Nghiệp vụ kho</div>
                <li><a asp-controller="NhapXuat" asp-action="PhieuNhap"><i class="fa-solid fa-file-import"></i> Phiếu nhập</a></li>
                <li><a asp-controller="NhapXuat" asp-action="PhieuXuat"><i class="fa-solid fa-file-export"></i> Phiếu xuất</a></li>
               
                <div class="menu-category">Báo cáo</div>
                <li><a asp-controller="BaoCao" asp-action="Kho"><i class="fa-solid fa-clipboard-list"></i> Hàng tồn kho</a></li>
                <li><a asp-controller="BaoCao" asp-action="Index"><i class="fa-solid fa-chart-line"></i> Xuất-Nhập-Tồn</a></li>
                
                <div class="menu-category">Phê duyệt</div>
                <li><a href="/Home/BaoTri"><i class="fa-solid fa-clipboard-list"></i> Duyệt phiếu nhập</a></li>
                <li><a href="/Home/BaoTri"><i class="fa-solid fa-chart-line"></i> Duyệt phiếu xuất</a></li>
                
                <div class="menu-category">Quản trị</div>
                <li><a asp-controller="QuanTri" asp-action="QuanLyTaiKhoan"><i class="fa-solid fa-user-shield"></i> Tài khoản <i class="fa-solid fa-lock" style="margin-left:auto; font-size: 10px;"></i></a></li>
                <li><a asp-controller="QuanTri" asp-action="PhanQuyen"><i class="fa-solid fa-key"></i> Phân quyền <i class="fa-solid fa-lock" style="margin-left:auto; font-size: 10px;"></i></a></li>
            </ul>
        </div>
    </aside>

    <div class="main-wrapper">
        <header class="topbar">
            <div class="topbar-left">
                <i class="fa-solid fa-bars" style="cursor: pointer; color: #64748b; font-size: 18px;"></i>
                <div class="search-box">
                    <i class="fa-solid fa-magnifying-glass" style="color: #94a3b8;"></i>
                    <input type="text" placeholder="Tìm kiếm nhanh (ví dụ: tên vật tư)...">
                </div>
            </div>

            <div class="topbar-right">
                <div class="notification">
                    <i class="fa-regular fa-bell"></i>
                    <span class="badge">1</span>
                </div>

                <div class="user-dropdown" onclick="toggleDropdown()">
                    <i class="fa-solid fa-circle-user" style="font-size: 28px; color: #94a3b8;"></i>
                    <span style="font-size: 14px; font-weight: 500;">@fullName</span>
                    <i class="fa-solid fa-chevron-down" style="font-size: 12px; color: #64748b;"></i>

                    <div class="user-dropdown-menu" id="profileMenu">
                        <a asp-controller="NguoiDung" asp-action="TaiKhoanCaNhan"><i class="fa-regular fa-user"></i> Tài khoản cá nhân</a>
                        <a asp-controller="NguoiDung" asp-action="TaiKhoanCaNhan"><i class="fa-solid fa-lock"></i> Đổi mật khẩu</a>
                        <div style="border-top: 1px solid #e2e8f0; margin: 5px 0;">
                            <form asp-controller="NguoiDung" asp-action="DangXuat" method="post" style="margin: 0; padding: 0;">
                                <button type="submit" style="background: none; border: none; color: #ef4444; width: 100%; text-align: left; padding: 10px 20px; cursor: pointer; font-size: 1rem; display: flex; align-items: center; gap: 8px; font-family: inherit;">
                                    <i class="fa-solid fa-arrow-right-from-bracket" style="width: 20px;"></i> Đăng xuất
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <main class="content-area">
            @RenderBody()
        </main>

        <footer class="footer">
            &copy; 2026 Quản Lý Vật Tư. Phiên bản v1.0.0
        </footer>
    </div>

    <script>
            function toggleDropdown() {
                var menu = document.getElementById("profileMenu");
                if (menu.style.display === "none" || menu.style.display === "") {
                    menu.style.display = "block";
                } else {
                    menu.style.display = "none";
                }
            }

            // Click ra ngoài để đóng menu
            window.onclick = function(event) {
                if (!event.target.closest('.user-dropdown')) {
                    var menu = document.getElementById("profileMenu");
                    if (menu && menu.style.display === "block") {
                        menu.style.display = "none";
                    }
                }
            }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>