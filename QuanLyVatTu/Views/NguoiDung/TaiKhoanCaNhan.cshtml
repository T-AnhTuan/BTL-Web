@model QuanLyVatTu.ViewModels.TaiKhoanCaNhanVM
@{
    ViewData["Title"] = "Hồ Sơ Cá Nhân";
}
<head>
    <link rel="stylesheet" href="~/css/taikhoan.css" asp-append-version="true">
</head>

<h1 class="page-title">Hồ Sơ Cá Nhân</h1>

<!-- Hiển thị thông báo thành công/thất bại từ Controller -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="padding: 15px; background-color: #d4edda; color: #155724; border-radius: 5px; margin-bottom: 20px;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="padding: 15px; background-color: #f8d7da; color: #721c24; border-radius: 5px; margin-bottom: 20px;">
        @TempData["ErrorMessage"]
    </div>
}

<form asp-action="CapNhatHoSo" asp-controller="NguoiDung" method="post" enctype="multipart/form-data">
    <!-- Gửi kèm các ID ngầm để Controller biết đang sửa ai -->
    <input type="hidden" asp-for="TaiKhoanId" />
    <input type="hidden" asp-for="NhanVienId" />
    <input type="hidden" asp-for="AvatarUrl" />

    <div class="profile-container">

        <div class="card-panel">
            <h2 class="card-title">Thông Tin Cơ Bản</h2>

            <div class="basic-info-layout">
                <div class="avatar-section">
                    <div class="avatar-circle">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <!-- Load ảnh từ DB nếu có -->
                            <img id="imagePreview" src="@Model.AvatarUrl" alt="Avatar" style="display: block; width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                            <i class="fa-solid fa-user" id="defaultAvatarIcon" style="display: none;"></i>
                        }
                        else
                        {
                            <!-- Hiện icon mặc định nếu chưa có ảnh -->
                            <i class="fa-solid fa-user" id="defaultAvatarIcon"></i>
                            <img id="imagePreview" src="#" alt="Avatar Preview" style="display: none; width: 100%; height: 100%; object-fit: cover; border-radius: 50%;" />
                        }
                    </div>
                    <!-- Input File ẩn, map với thuộc tính AvatarUpload -->
                    <input type="file" asp-for="AvatarUpload" id="avatarUpload" accept="image/*" style="display: none;">

                    <button type="button" class="btn btn-outline" style="width: 100%; padding: 6px 10px; font-size: 13px;" onclick="document.getElementById('avatarUpload').click();">Thay đổi ảnh hồ sơ</button>
                </div>

                <div class="form-fields">
                    <div class="form-group">
                        <label asp-for="HoTen"></label>
                        <input type="text" asp-for="HoTen" placeholder="Nhập họ tên...">
                        <span asp-validation-for="HoTen" style="color: red; font-size: 12px;"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="TenDangNhap"></label>
                        <!-- Dùng readonly vì không cho phép đổi tên đăng nhập -->
                        <input type="text" asp-for="TenDangNhap" readonly title="Tên đăng nhập không thể thay đổi" style="background-color: #f0f0f0;">
                    </div>

                    <div class="form-group">
                        <label asp-for="Email"></label>
                        <input type="email" asp-for="Email" placeholder="Nhập địa chỉ email...">
                        <span asp-validation-for="Email" style="color: red; font-size: 12px;"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="SoDienThoai"></label>
                        <input type="text" asp-for="SoDienThoai" placeholder="Nhập số điện thoại...">
                    </div>

                    <div class="form-group">
                        <label asp-for="VaiTro"></label>
                        <input type="text" asp-for="VaiTro" readonly title="Vai trò do Admin cấp phát" style="background-color: #f0f0f0;">
                    </div>
                </div>
            </div>
        </div>

        <div class="card-panel" style="display: flex; flex-direction: column; justify-content: space-between;">
            <div>
                <h2 class="card-title">Bảo Mật</h2>
                <p style="font-size: 13px; color: #666; margin-bottom: 15px;">(Bỏ trống nếu không muốn đổi mật khẩu)</p>

                <div class="form-fields">
                    <div class="form-group">
                        <label asp-for="MatKhauHienTai"></label>
                        <input type="password" asp-for="MatKhauHienTai" placeholder="Nhập mật khẩu đang sử dụng...">
                    </div>

                    <div class="form-group">
                        <label asp-for="MatKhauMoi"></label>
                        <input type="password" asp-for="MatKhauMoi" placeholder="Nhập mật khẩu mới...">
                        <span asp-validation-for="MatKhauMoi" style="color: red; font-size: 12px;"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="XacNhanMatKhauMoi"></label>
                        <input type="password" asp-for="XacNhanMatKhauMoi" placeholder="Nhập lại mật khẩu mới...">
                        <span asp-validation-for="XacNhanMatKhauMoi" style="color: red; font-size: 12px;"></span>
                    </div>
                </div>
            </div>

            <div class="action-bar">
                <a href="/Home/Index" class="btn btn-secondary" style="text-decoration: none; text-align: center;">Hủy bỏ</a>
                <!-- Đổi button type thành submit để Form gửi dữ liệu lên Server -->
                <button type="submit" class="btn btn-primary"><i class="fa-solid fa-floppy-disk" style="margin-right: 8px;"></i> Lưu thay đổi</button>
            </div>
        </div>

    </div>
</form>

<script>
    const avatarUpload = document.getElementById('avatarUpload');
    const imagePreview = document.getElementById('imagePreview');
    const defaultAvatarIcon = document.getElementById('defaultAvatarIcon');

    avatarUpload.addEventListener('change', function() {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                imagePreview.src = e.target.result;
                imagePreview.style.display = 'block';
                if(defaultAvatarIcon) defaultAvatarIcon.style.display = 'none';
            }
            reader.readAsDataURL(file);
        }
    });
</script>