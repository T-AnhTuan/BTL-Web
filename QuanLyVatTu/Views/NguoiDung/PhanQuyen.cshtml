@{
    ViewData["Title"] = "Quản Lý Vai Trò và Phân Quyền";
}
<head>
    <link rel="stylesheet" href="~/css/phanquyen.css" asp-append-version="true">
</head>

<div class="page-header">
    <h1 class="page-title">Quản lý vai trò và Phân quyền</h1>
    <div style="display: flex; gap: 10px;">
        <button id="btnSaveConfig" class="btn btn-dark"><i class="fa-solid fa-floppy-disk"></i> Lưu Cấu Hình Phân Quyền</button>
        <button class="btn btn-outline">Hủy bỏ</button>
    </div>
</div>

<div class="permissions-container">

    <div class="roles-sidebar">
        <ul class="role-list">
            <li class="active">Quản trị viên</li>
            <li>Thủ kho</li>
            <li>Kế toán</li>
            <li>Nhân viên</li>
        </ul>
        <button id="btnOpenRoleModal" class="btn-add-role"><i class="fa-solid fa-plus"></i> Thêm Vai Trò Mới</button>
    </div>

    <div class="matrix-content">
        <div class="info-alert">
            <i class="fa-solid fa-circle-info"></i>
            <span>Cấu hình phân quyền cho vai trò: <strong>Quản trị viên</strong></span>
        </div>

        <table class="data-table">
            <thead>
                <tr>
                    <th colspan="2">Chức Năng</th>
                    <th style="width: 80px;">Xem</th>
                    <th style="width: 80px;">Thêm</th>
                    <th style="width: 80px;">Sửa</th>
                    <th style="width: 80px;">Xóa</th>
                    <th style="width: 100px;">Phê Duyệt</th>
                    <th style="width: 120px;">Toàn Quyền</th>
                </tr>
            </thead>
            <tbody>
                <tr class="quick-select-row">
                    <td colspan="2"><input type="text" placeholder="Tìm kiếm nhanh..."></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td><input type="checkbox" title="Chọn tất cả"></td>
                </tr>

                <tr>
                    <td>Vật Tư</td>
                    <td>Vật Tư</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                </tr>

                <tr>
                    <td>Danh Mục</td>
                    <td>Danh Mục</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox"></td>
                    <td><input type="checkbox" checked></td>
                </tr>

                <tr>
                    <td rowspan="3">Nghiệp vụ Kho</td>
                    <td>Phiếu Nhập</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                </tr>
                <tr>
                    <td>Phiếu Xuất</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                </tr>
                <tr>
                    <td>Thẻ Kho</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox"></td>
                    <td><input type="checkbox" checked></td>
                </tr>

                <tr>
                    <td>Báo Cáo</td>
                    <td>Báo Cáo</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                </tr>

                <tr>
                    <td rowspan="2">Quản Trị</td>
                    <td>Quản trị Tài khoản</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox"></td>
                    <td><input type="checkbox" checked></td>
                </tr>
                <tr>
                    <td>Phân Quyền</td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox" checked></td>
                    <td><input type="checkbox"></td>
                    <td><input type="checkbox" checked></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div id="addRoleModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fa-solid fa-shield-halved" style="color:#1e293b; margin-right:8px;"></i> THÊM VAI TRÒ MỚI</h3>
            <button id="btnCloseRoleModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
            <div class="form-group">
                <label>Tên Vai Trò (Role Name) <span style="color:red">*</span></label>
                <input type="text" placeholder="Ví dụ: Giám đốc, Quản lý chi nhánh...">
            </div>
            <div class="form-group">
                <label>Ghi chú / Mô tả</label>
                <input type="text" placeholder="Nhập mô tả cho vai trò này...">
            </div>
        </div>

        <div class="modal-footer">
            <button id="btnCancelRole" class="btn btn-cancel">Hủy Bỏ</button>
            <button id="btnSaveRole" class="btn btn-dark"><i class="fa-solid fa-floppy-disk"></i> Lưu Vai Trò</button>
        </div>
    </div>
</div>

<script src="~/js/phanquyen.js" asp-append-version="true">
  
</script>