@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập Hệ thống</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

</head>
<body>

    <div class="background-wrapper">
        <aside class="pccv">
            <h2>
                Phân công nhiệm vụ
            </h2>
            <div class="pccv-card">
                <div class="name-card">
                    <div class="name-info">
                        <h4 class="hoten">Trần Anh Tuấn
                            <span style="font-size: 15px; font-style:italic"> (STT: 26) </span>
                        </h4>
                        <span style="font-weight: 470; margin-top: 7px; font-size: 15px;">Nhiệm vụ: </span>
                        <p>Trưởng nhóm, Back-End, phụ trách Controllers, Services</p>
                    </div>
                </div>
                <div class="name-card">

                    <div class="name-info">
                        <h4 class="hoten">Nguyễn Trần Hải Duyên
                            <span style="font-size: 15px; font-style:italic"> (STT: 2) </span>
                        </h4>
                        <span style="font-weight: 470; margin-top: 7px; font-size: 15px;">Nhiệm vụ: </span>
                        <p>Front-End, phụ trách Views</p>
                    </div>
                </div>
                <div class="name-card">

                    <div class="name-info">
                        <h4 class="hoten">Nguyễn Thu Huyền
                            <span style="font-size: 15px; font-style:italic"> (STT: 14) </span>
                        </h4>
                        <span style="font-weight: 470; margin-top: 7px; font-size: 15px;">Nhiệm vụ: </span>
                        <p>Thiết kế Database, Models, kiểm thử</p>
                    </div>
                </div>
                <div class="name-card" style="display: flex; align-items: center; gap: 12px; padding: 12px 0; border-bottom: none;">

                    <div class="name-info">
                        <h4 class="hoten">Nguyễn Hà Phương Anh
                            <span style="font-size: 15px; font-style:italic"> (STT: 6) </span>
                        </h4>
                        <span style="font-weight: 470; margin-top: 7px; font-size: 15px;">Nhiệm vụ: </span>
                        <p>Kiểm thử, hỗ trợ thiết kế giao diện</p>
                    </div>
                </div>
            </div>
        </aside>
        <div class="login-box">
            <h1 class="title"> HỆ THỐNG QUẢN LÝ KHO VẬT TƯ</h1>
            <div class="subtitle">ĐĂNG NHẬP HỆ THỐNG</div>

            <div class="warehouse-icon">
                <img src="~/image/logo.png" alt="Logo Hệ Thống" style="height: 80px;" />
            </div>

            <form asp-controller="NguoiDung" asp-action="DangNhap" method="post">
                <div asp-validation-summary="All" 
                    style="color: red; font-size: 13px; text-align:center; margin-bottom: 15px;">
                </div>
                <div class="input-group">
                    <i class="fa-regular fa-user left-icon"></i>
                    <input type="text"name="username" placeholder="Tên đăng nhập">
                </div>

                <div class="input-group">
                    <i class="fa-solid fa-lock left-icon"></i>
                    <input type="password" name="password" id="passwordInput" placeholder="Mật khẩu">
                    <i class="fa-solid fa-eye-slash right-icon" id="togglePassword" style="cursor: pointer;" title="Hiển thị mật khẩu"></i>
                </div>

                <div class="options" >
                    <label>
                        <input type="checkbox"> Ghi nhớ đăng nhập
                    </label>
                   <!--<a href="/Home/Baotri" target="_blank">Quên mật khẩu?</a>-->
                </div>

                <button type="submit" class="login-btn">ĐĂNG NHẬP</button>
            </form>
        </div>
        <aside class="tk-demo">
            <h2>
                Tài khoản dùng thử
            </h2>
            <div style="display: flex; flex-direction: column;">
                <div class="tk-card">
                    <div class="tk-role">Quản trị viên</div>
                    <div style="font-family: monospace; font-size: 13px; color: #191c23; display: flex; flex-direction: column; gap: 2px;">
                        <span style="display: block;">Tên đăng nhập: <strong style="color: #005bbf;">admin</strong></span>
                        <span style="display: block;">Mật khẩu: <strong style="color: #005bbf;">Admin@123</strong></span>
                    </div>
                </div>
                <div class="tk-card">
                    <div class="tk-role">Quản lý</div>
                    <div style="font-family: monospace; font-size: 13px; color: #191c23; display: flex; flex-direction: column; gap: 2px;">
                        <span style="display: block;">Tên đăng nhập: <strong style="color: #005bbf;">huyen</strong></span>
                        <span style="display: block;">Mật khẩu: <strong style="color: #005bbf;">huyen123</strong></span>
                    </div>
                </div>
                <div class="tk-card" style="opacity: 0.8;">
                    <div class="tk-role">Nhân viên</div>
                    <div style="font-family: monospace; font-size: 13px; color: #191c23; display: flex; flex-direction: column; gap: 2px;">
                        <span style="display: block;">Tên đăng nhập: <strong style="color: #005bbf;">anh</strong></span>
                        <span style="display: block;">Mật khẩu: <strong style="color: #005bbf;">anh123</strong></span>
                    </div>
                </div>
            </div>
            <p style="font-size: 11px; color: #727785; margin-top: 16px; font-style: italic; margin-bottom: 0;">
                * Vui lòng không thay đổi mật khẩu tài khoản demo.
            </p>
        </aside>
    </div>
    
    <script>
            document.addEventListener('DOMContentLoaded', function () {
                const togglePassword = document.getElementById('togglePassword');
                const passwordInput = document.getElementById('passwordInput');

                togglePassword.addEventListener('click', function () {
                    // Kiểm tra type hiện tại của ô input
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);

                    // Đổi icon con mắt
                    this.classList.toggle('fa-eye-slash');
                    this.classList.toggle('fa-eye');

                    // Đổi tiêu đề tooltip khi rê chuột
                    if(type === 'text') {
                        this.setAttribute('title', 'Ẩn mật khẩu');
                    } else {
                        this.setAttribute('title', 'Hiển thị mật khẩu');
                    }
                });
            });
    </script>
</body>
</html>