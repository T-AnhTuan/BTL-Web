@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập Hệ thống</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>

    <div class="background-wrapper">
        <div class="login-box">
            <div class="title">HỆ THỐNG QUẢN LÝ VẬT TƯ<br>& HÀNG TỒN KHO</div>
            <div class="subtitle">ĐĂNG NHẬP HỆ THỐNG</div>

            <div class="warehouse-icon">
                <img src="~/image/logo.png" alt="Logo Hệ Thống" style="height: 80px;" />
            </div>

            <form asp-controller="NguoiDung" asp-action="DangNhap" method="post">
                <div asp-validation-summary="All" 
                    style="color: red; font-size: 13px; text-align:center; margin-bottom: 15px;">
                </div>
                <div class="input-group">
                    <i class="fa-regular fa-user left-icon"></i>
                    <input type="text"name="username" placeholder="Tên đăng nhập">
                </div>

                <div class="input-group">
                    <i class="fa-solid fa-lock left-icon"></i>
                    <input type="password" name="password" id="passwordInput" placeholder="Mật khẩu">
                    <i class="fa-solid fa-eye-slash right-icon" id="togglePassword" style="cursor: pointer;" title="Hiển thị mật khẩu"></i>
                </div>

                <div class="options">
                    <label>
                        <input type="checkbox"> Ghi nhớ đăng nhập
                    </label>
                    <a href="/Home/Baotri" target="_blank">Quên mật khẩu?</a>
                </div>

                <button type="submit" class="login-btn">ĐĂNG NHẬP</button>
            </form>
        </div>
    </div>
    <script>
            document.addEventListener('DOMContentLoaded', function () {
                const togglePassword = document.getElementById('togglePassword');
                const passwordInput = document.getElementById('passwordInput');

                togglePassword.addEventListener('click', function () {
                    // Kiểm tra type hiện tại của ô input
                    const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordInput.setAttribute('type', type);

                    // Đổi icon con mắt
                    this.classList.toggle('fa-eye-slash');
                    this.classList.toggle('fa-eye');

                    // Đổi tiêu đề tooltip khi rê chuột
                    if(type === 'text') {
                        this.setAttribute('title', 'Ẩn mật khẩu');
                    } else {
                        this.setAttribute('title', 'Hiển thị mật khẩu');
                    }
                });
            });
    </script>
</body>
</html>