@using QuanLyVatTu.Models
@model QuanLyVatTu.ViewModels.BaoCaoVM
@{
    ViewData["Title"] = "Báo Cáo Xuất-Nhập-Tồn Vật Tư";
}
<link rel="stylesheet" href="~/css/baocao.css" asp-append-version="true">

<h1 class="page-title">Báo Cáo Xuất-Nhập-Tồn Vật Tư</h1>

<div class="filter-toolbar">
    <div class="filter-group-wrapper">
        <div class="filter-box">
            <label>Kho</label>
            <select class="input-control" asp-for="KhoId" asp-items="@(ViewBag.DanhSachKho ?? ViewBag.DanhMucKhos)">
                <option value="">-- Tất cả các kho --</option>
            </select>
        </div>

        <div class="filter-box">
            <label>Từ Ngày</label>
            <input type="date" asp-for="TuNgay" class="input-control">
        </div>

        <div class="filter-box" style="justify-content: center; padding-top: 25px;">
            <span style="color: #94a3b8; font-weight: bold;">-</span>
        </div>

        <div class="filter-box">
            <label>Đến Ngày</label>
            <input type="date" asp-for="DenNgay" class="input-control">
        </div>

        <div class="filter-box">
            <label>Tên/Mã VT</label>
            <input type="text" asp-for="TuKhoa" class="input-control" placeholder="Nhập để tìm kiếm...">
        </div>

        <div class="filter-box" style="justify-content: flex-end;">
            <button type="submit" class="btn btn-primary">Xem báo cáo</button>
        </div>
    </div>

    <div class="action-group">
        <button href="/Home/BaoTri" class="btn btn-outline"><i class="fa-solid fa-file-excel" style="color: #10b981;"></i> Xuất Excel</button>
        <button href="/Home/BaoTri" class="btn btn-outline"><i class="fa-solid fa-print"></i> In</button>
    </div>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th rowspan="2" style="width: 50px;">STT</th>
                <th rowspan="2">Mã Vật Tư</th>
                <th rowspan="2">Tên Vật Tư</th>
                <th rowspan="2" style="width: 60px;">ĐVT</th>
                <th colspan="2">Tồn Đầu Kỳ</th>
                <th colspan="2">Nhập Trong Kỳ</th>
                <th colspan="2">Xuất Trong Kỳ</th>
                <th colspan="2">Tồn Cuối Kỳ</th>
            </tr>
            <tr>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.DanhSachChiTiet != null && Model.DanhSachChiTiet.Any())
            {
                foreach (var item in Model.DanhSachChiTiet)
                {
                    <tr>
                        <td class="text-center fw-bold text-secondary">@item.VatTuId</td>
                        <td class="text-center fw-bold text-secondary">@item.MaVatTu</td>
                        <td>@item.TenVatTu</td>
                        <td class="text-center">@item.DonViTinh</td>

                        <!-- Tồn đầu -->
                        <td class="text-end">@item.TonDauSoLuong.ToString("N0")</td>
                        <td class="text-end">@item.TonDauGiaTri.ToString("N0")</td>

                        <!-- Nhập -->
                        <td class="text-end text-success fw-semibold">@item.NhapSoLuong.ToString("N0")</td>
                        <td class="text-end text-success">@item.NhapGiaTri.ToString("N0")</td>

                        <!-- Xuất -->
                        <td class="text-end text-danger fw-semibold">@item.XuatSoLuong.ToString("N0")</td>
                        <td class="text-end text-danger">@item.XuatGiaTri.ToString("N0")</td>

                        <!-- Tồn cuối -->
                        <td class="text-end fw-bold text-primary">@item.TonCuoiSoLuong.ToString("N0")</td>
                        <td class="text-end fw-bold text-primary">@item.TonCuoiGiaTri.ToString("N0")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="11" class="text-center py-5 text-muted">
                        <i class="fa-solid fa-box-open fs-1 mb-3 text-light"></i><br />
                        Không tìm thấy dữ liệu báo cáo trong khoảng thời gian này.
                    </td>
                </tr>
            }
        </tbody>

        @if (Model != null && Model.DanhSachChiTiet != null && Model.DanhSachChiTiet.Any())
        {
            <tfoot class="table-light fw-bold">
                <tr>
                    <td colspan="4" class="text-center text-uppercase">Tổng cộng</td>
                    <td class="text-end">@Model.TongTonDauSoLuong.ToString("N0")</td>
                    <td class="text-end">@Model.TongTonDauGiaTri.ToString("N0") VNĐ</td>
                    <td class="text-end text-success">@Model.TongNhapSoLuong.ToString("N0")</td>
                    <td class="text-end text-success">@Model.TongNhapGiaTri.ToString("N0") VNĐ</td>
                    <td class="text-end text-danger">@Model.TongXuatSoLuong.ToString("N0")</td>
                    <td class="text-end text-danger">@Model.TongXuatGiaTri.ToString("N0") VNĐ</td>
                    <td class="text-end text-primary fs-6">@Model.TongTonCuoiSoLuong.ToString("N0")</td>
                    <td class="text-end text-primary fs-6">@Model.TongTonCuoiGiaTri.ToString("N0") VNĐ</td>
                </tr>
            </tfoot>
        }
    </table>
</div>