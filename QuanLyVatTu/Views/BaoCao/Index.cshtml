@model QuanLyVatTu.ViewModels.BaoCaoVM
@{
    ViewData["Title"] = "Báo Cáo Xuất-Nhập-Tồn Vật Tư";
}
<link rel="stylesheet" href="~/css/baocao.css" asp-append-version="true">

<h1 class="page-title">Báo Cáo Xuất-Nhập-Tồn Vật Tư</h1>

<div class="filter-toolbar">
    <div class="filter-group-wrapper">
        <div class="filter-box">
            <label>Kho</label>
            <select class="input-control">
                <option value="">Tất cả các kho</option>
            </select>
        </div>

        <div class="filter-box">
            <label>Từ Ngày</label>
            <input type="date" class="input-control">
        </div>

        <div class="filter-box" style="justify-content: center; padding-top: 25px;">
            <span style="color: #94a3b8; font-weight: bold;">-</span>
        </div>

        <div class="filter-box">
            <label>Đến Ngày</label>
            <input type="date" asp-for="TuNgay" class="input-control">
        </div>

        <div class="filter-box">
            <label>Tên/Mã VT</label>
            <input type="text" asp-for="TuKhoa" class="input-control" placeholder="Nhập để tìm kiếm...">
        </div>

        <div class="filter-box" style="justify-content: flex-end;">
            <button class="btn btn-primary">Xem Báo Cáo</button>
        </div>
    </div>

    <div class="action-group">
        <button class="btn btn-outline"><i class="fa-solid fa-file-excel" style="color: #10b981;"></i> Xuất Excel</button>
        <button class="btn btn-outline"><i class="fa-solid fa-print"></i> In</button>
    </div>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th rowspan="2" style="width: 50px;">STT</th>
                <th rowspan="2">Mã Vật Tư</th>
                <th rowspan="2">Tên Vật Tư</th>
                <th rowspan="2" style="width: 60px;">ĐVT</th>
                <th colspan="2">Tồn Đầu Kỳ</th>
                <th colspan="2">Nhập Trong Kỳ</th>
                <th colspan="2">Xuất Trong Kỳ</th>
                <th colspan="2">Tồn Cuối Kỳ</th>
            </tr>
            <tr>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
                <th style="width: 80px;">Số lượng</th>
                <th style="width: 120px;">Giá trị</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.DanhSachChiTiet)
            {
                <tr>
                    <td>@item.MaVatTu</td>
                    <td>@item.TenVatTu</td>
                    <!-- Các cột Tồn đầu, Nhập, Xuất, Tồn cuối... -->
                    <td class="text-right">@item.TonDauSoLuong</td>
                    <td class="text-right">@item.TonDauGiaTri.ToString("N0")</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="4" class="text-center">Tổng Cộng</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
                <td class="text-right">0</td>
            </tr>
        </tfoot>
    </table>
</div>