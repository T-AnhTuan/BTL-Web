@* Trang này chỉ dùng để điều hướng, không cần nhận Model *@
@{
    ViewData["Title"] = "Trung Tâm Báo Cáo";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h2 class="text-primary fw-bold"><i class="fas fa-chart-line me-2"></i> TRUNG TÂM BÁO CÁO & THỐNG KÊ</h2>
        <p class="text-muted">Vui lòng chọn loại báo cáo bạn muốn xem hoặc in ấn</p>
    </div>

    <div class="row justify-content-center">
        <!-- 1. THẺ BÁO CÁO TỒN KHO -->
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0 bg-light text-center p-3 hover-effect">
                <div class="card-body">
                    <i class="fas fa-warehouse text-info mb-3" style="font-size: 50px;"></i>
                    <h4 class="card-title text-dark fw-bold">Báo Cáo Tồn Kho</h4>
                    <p class="card-text text-secondary mb-4">
                        Xem chi tiết số lượng, giá trị tồn kho hiện tại của tất cả mặt hàng và theo dõi cảnh báo sắp hết hàng.
                    </p>
                    <a href="/BaoCao/bcTonKho" class="btn btn-info text-white rounded-pill px-4">
                        <i class="fas fa-eye me-1"></i> Xem Báo Cáo
                    </a>
                </div>
            </div>
        </div>

        <!-- 2. THẺ BÁO CÁO NHẬP XUẤT -->
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0 bg-light text-center p-3 hover-effect">
                <div class="card-body">
                    <i class="fas fa-file-invoice-dollar text-success mb-3" style="font-size: 50px;"></i>
                    <h4 class="card-title text-dark fw-bold">Báo Cáo Nhập / Xuất</h4>
                    <p class="card-text text-secondary mb-4">
                        Tra cứu lịch sử nhập xuất hàng hóa, kiểm tra người duyệt phiếu và tổng hợp số tiền theo khoảng thời gian.
                    </p>
                    <a href="/BaoCao/bcNhapXuat" class="btn btn-success rounded-pill px-4">
                        <i class="fas fa-eye me-1"></i> Xem Báo Cáo
                    </a>
                </div>
            </div>
        </div>

        <!-- 3. THẺ PHÂN TÍCH THỐNG KÊ -->
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0 bg-light text-center p-3 hover-effect">
                <div class="card-body">
                    <i class="fas fa-chart-pie text-warning mb-3" style="font-size: 50px;"></i>
                    <h4 class="card-title text-dark fw-bold">Phân Tích Thống KÊ</h4>
                    <p class="card-text text-secondary mb-4">
                        Xem biểu đồ trực quan về cơ cấu hàng tồn kho theo đơn vị tính, đánh giá tỷ lệ và hiệu suất luân chuyển kho.
                    </p>
                    <a href="/BaoCao/PhanTichThongKe" class="btn btn-warning text-dark fw-bold rounded-pill px-4">
                        <i class="fas fa-eye me-1"></i> Xem Phân Tích
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@* Thêm một chút CSS làm hiệu ứng phóng to thẻ khi di chuột vào cho trang web sinh động *@
<style>
    .hover-effect {
        transition: transform 0.3s ease-in-out, box-shadow 0.3s ease-in-out;
    }

        .hover-effect:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.15) !important;
            background-color: #ffffff !important;
        }
</style>