@* Khai báo ViewModel để nhận dữ liệu từ Controller (Đã xóa chữ @page) *@
@model QuanLyVatTu.ViewModels.BaoCao.bcTonKhoVM

@{
    ViewData["Title"] = "Báo Cáo Tồn Kho";
}

<!-- Đoạn CSS này chỉ kích hoạt khi người dùng bấm Ctrl + P (Lệnh In) -->
<style type="text/css" media="print">
    /* Ẩn tất cả các thẻ có class là 'no-print' (Ví dụ: nút bấm, menu) */
    .no-print { display: none !important; }
    /* Hiện thẻ có class 'only-print' (Ví dụ: Tiêu đề công ty lúc in giấy mới thấy) */
    .only-print { display: block !important; }
    /* Chỉnh chữ màu đen hết cho rõ nét trên giấy */
    body { color: black !important; background: white !important; }
    /* Căn lề khổ giấy A4 */
    @page { size: A4; margin: 20mm; }
</style>

<!-- CSS ẩn các thành phần in lúc đang xem trên web -->
<style type="text/css" media="screen">
    .only-print { display: none; }
</style>

<div class="container mt-4">
    
    <!-- KHU VỰC NÀY CHỈ HIỆN TRÊN GIẤY IN (Header của công ty) -->
    <div class="only-print text-center mb-4">
        <h2>CÔNG TY QUẢN LÝ VẬT TƯ XYZ</h2>
        <h4>BÁO CÁO TỔNG HỢP TỒN KHO</h4>
        <p>Ngày in: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
        <hr />
    </div>

    <!-- Nút bấm in báo cáo (Sẽ bị ẩn đi khi in ra giấy nhờ class no-print) -->
    <div class="d-flex justify-content-between align-items-center mb-4 no-print">
        <h2 class="text-primary">@ViewData["Title"]</h2>
        <!-- Nút bấm gọi hàm window.print() của trình duyệt -->
        <button onclick="window.print()" class="btn btn-primary">
            <i class="fas fa-print"></i> In Báo Cáo
        </button>
    </div>

    <!-- Bảng hiển thị tóm tắt -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="alert alert-info">
                <strong>Tổng loại vật tư:</strong> @Model.TongSoLoaiVatTu
            </div>
        </div>
        <div class="col-md-4">
            <div class="alert alert-success">
                <strong>Tổng giá trị:</strong> @Model.TongGiaTriTonKho.ToString("N0") VNĐ
            </div>
        </div>
        <div class="col-md-4">
            <div class="alert alert-danger">
                <strong>Sắp hết hàng:</strong> @Model.CanhBaoHetHang (mặt hàng)
            </div>
        </div>
    </div>

    <!-- Bảng chi tiết vật tư -->
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Mã VT</th>
                <th>Tên Vật Tư</th>
                <th>Đơn vị tính</th>
                <th>Số lượng tồn</th>
                <th>Giá vốn bình quân</th>
                <th>Thành tiền</th>
            </tr>
        </thead>
        <tbody>
            @* Vòng lặp lấy từng mặt hàng trong DanhSachVatTu để in thành 1 dòng <tr> *@
            @foreach (var item in Model.DanhSachVatTu)
            {
                // Biến tạm để tính thành tiền = Số lượng * Giá vốn
                decimal thanhTien = item.SoLuongTon * item.GiaVonTB; 
                <tr>
                    <td>@item.Id</td>
                    <td>@item.TenVatTu</td>
                    <td>@item.DonViTinh</td>
                    <!-- Nếu tồn kho thấp thì in chữ màu đỏ báo hiệu -->
                    <td class="@(item.SoLuongTon <= 10 ? "text-danger fw-bold" : "")">
                        @item.SoLuongTon
                    </td>
                    <!-- ToString("N0") giúp định dạng số 1000000 thành 1,000,000 -->
                    <td>@item.GiaVonTB.ToString("N0")</td>
                    <td>@thanhTien.ToString("N0")</td>
                </tr>
            }
        </tbody>
    </table>

    <!-- Chữ ký ở cuối trang in -->
    <div class="only-print mt-5 row text-center">
        <div class="col-6"><strong>Người Lập Biểu</strong><br/>(Ký, ghi rõ họ tên)</div>
        <div class="col-6"><strong>Giám Đốc</strong><br/>(Ký, đóng dấu)</div>
    </div>
</div>