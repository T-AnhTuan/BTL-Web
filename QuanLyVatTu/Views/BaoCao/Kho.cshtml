@using QuanLyVatTu.ViewModels
@model KhoVM
@{
    ViewData["Title"] = "Báo Cáo Chi Tiết Thẻ Kho";
}

<link rel="stylesheet" href="~/css/kho.css" asp-append-version="true" />

<h1 class="page-title">BÁO CÁO HÀNG TỒN KHO</h1>
<form method="get" asp-controller="BaoCao" asp-action="Kho" class="filter-toolbar">
    <div class="filter-box">
        <i class="fa-solid fa-magnifying-glass"></i>
        <select class="select-vattu">
            <option value="">Chọn vật tư...</option>
            @if (ViewBag.VatTus != null)
            {
                foreach (var vt in ViewBag.VatTus)
                {
                    <option value="@vt.Id" selected="@(Model?.VatTuId == vt.Id ? "selected" : null)">
                        @vt.TenVatTu
                    </option>
                }
            }
        </select>
    </div>

    <input type="date" name="tuNgay" class="input-date" title="Từ ngày" value="@ViewBag.TuNgay">
    <input type="date" name="denNgay" class="input-date" title="Đến ngày" value="@ViewBag.DenNgay">

    <button class="btn btn-primary">Xem báo cáo</button>
</form>
<div class="table-container">
    <div class="table-header-title">
        Kho Vật Tư: @(Model?.TenVatTu ?? "[Chưa chọn vật tư]") - Kho: @(Model?.TenKho ?? "Kho Tổng")
    </div>
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 50px;">STT</th>
                <th style="width: 120px;">Ngày</th>
                <th style="width: 150px;">Số chứng từ</th>
                <th>Diễn Giải</th>
                <th style="width: 100px;">Nhập</th>
                <th style="width: 100px;">Xuất</th>
                <th style="width: 120px;">Tồn</th>
                <th style="width: 100px;">Ghi chú</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.ChiTietGiaoDich != null && Model.ChiTietGiaoDich.Any())
            {
                int stt = 1;
                foreach (var dong in Model.ChiTietGiaoDich)
                {
                    <tr>
                        <td>@(stt++)</td>
                        <td>@dong.NgayGiaoDich.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="color: #0284c7; font-weight: 500;">@dong.SoChungTu</td>
                        <td>@dong.DienGiai</td>

                        <!-- Kiểm tra nếu là Nhập thì in cột Nhập, là Xuất thì in cột Xuất -->
                        <td style="color: #16a34a; font-weight: bold;">
                            @(dong.LoaiGiaoDich == "Nhập" ? dong.SoLuong.ToString("N0") : "")
                        </td>
                        <td style="color: #dc2626; font-weight: bold;">
                            @(dong.LoaiGiaoDich == "Xuất" ? dong.SoLuong.ToString("N0") : "")
                        </td>

                        <td style="font-weight: bold;">@dong.TonKhoSauGiaoDich.ToString("N0")</td>
                        <td style="font-size: 13px; color: #64748b;">@dong.GhiChu</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center" style="padding: 20px;">
                        Vui lòng chọn vật tư và thời gian để xem Thẻ Kho, hoặc không có giao dịch nào trong kỳ.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>