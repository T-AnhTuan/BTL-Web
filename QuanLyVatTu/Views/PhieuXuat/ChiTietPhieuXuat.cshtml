@model QuanLyVatTu.Models.PhieuXuat

@{
    ViewData["Title"] = "Thêm Chi Tiết Phiếu Xuất";
}

<link rel="stylesheet" href="~/css/ctXuat.css" asp-append-version="true" />

<div class="page-header">
    <div style="display: flex; align-items: center; gap: 15px;">
        <a asp-controller="PhieuXuat" asp-action="PhieuXuat" class="btn btn-secondary" title="Quay lại" style="text-decoration: none;"><i class="fa-solid fa-arrow-left"></i></a>
        <h1 class="page-title">Chi tiết phiếu xuất</h1>
    </div>
    <div style="display: flex; gap: 10px;">
        <button class="btn btn-secondary"><i class="fa-solid fa-print"></i> In phiếu</button>
        <button id="btnLuuPhieu" class="btn btn-success" onclick="hoanTatPhieu()"><i class="fa-solid fa-check"></i> Hoàn tất phiếu</button>
    </div>
</div>

<div class="section-card">
    <div class="section-title"><i class="fa-solid fa-circle-info" style="color:#3b82f6;"></i> THÔNG TIN PHIẾU NHẬP</div>
    <div class="input-row">
        <!-- CÁC THẺ ẨN CHỨA DỮ LIỆU TẠM THỜI -->
        <input type="hidden" id="hdfPhieuXuatId" value="@Model.Id" />
        <input type="hidden" id="hdfNgayXuat" value="@Model.NgayXuat.ToString("dd/MM/yyyy HH:mm")" />
        <input type="hidden" id="hdfKhoId" value="@Model.KhoId" />
        <input type="hidden" id="hdfKhachHang" value="@Model.KhachHang" />
        <input type="hidden" id="hdfLyDoXuat" value="@Model.LyDoXuat" />

        <div class="form-group">
            <label>Mã phiếu</label>
            <input id="txtMaPhieu" value="@Model.MaPhieu" readonly class="form-control" style="background-color: #f8fafc;">
        </div>
        <div class="form-group">
            <label>Ngày xuất</label>
            <input value="@Model.NgayXuat.ToString("dd/MM/yyyy HH:mm")" readonly class="form-control" style="background-color: #f8fafc;">
        </div>
        <div class="form-group">
            <label>Kho xuất</label>
            <input id="cboKhoId" value="@Model.Kho?.TenKho" readonly class="form-control" style="background-color: #f8fafc;">
        </div>
        <div class="form-group">
            <label>Khách hàng</label>
            <input id="KhachHangid" value="@Model.KhachHang" readonly class="form-control" style="background-color: #f8fafc;">
        </div>
    </div>
</div>

<div class="section-card" style="background-color: #f8fafc; border-style: dashed; border-color: #94a3b8;">
    <div class="section-title"><i class="fa-solid fa-cart-plus" style="color:#10b981;"></i> THÊM VẬT TƯ VÀO PHIẾU</div>
    <div class="input-row" style="align-items: flex-end;">
        <div class="form-group" style="flex: 2;">
            <label>Chọn vật tư <span style="color:red">*</span></label>
            <select id="cboVatTu" class="form-control">
                <option value="">-- Vui lòng chọn vật tư --</option>
                @if (ViewBag.VatTus != null)
                {
                    foreach (var vt in ViewBag.VatTus)
                    {
                        <option value="@vt.Id" data-dvt="@vt.DonViTinh" data-code="@vt.MaVatTu">
                            [@vt.MaVatTu] - @vt.TenVatTu
                        </option>
                    }
                }
            </select>
        </div>
        <div class="form-group" style="flex: 0.5;">
            <label>Số lượng <span style="color:red">*</span></label>
            <input type="number" id="txtSoLuong" min="1" placeholder="Nhập số lượng...">
        </div>
        <div class="form-group" style="flex: 1;">
            <label>Đơn giá (VNĐ) <span style="color:red">*</span></label>
            <input type="text" id="txtDonGia" min="0" placeholder="Tự lấy giá vốn..." style="font-weight: bold;" readonly>
        </div>
        <div class="form-group" style="flex: 0;">
            <button type="button" id="btnThemVatTu" class="btn btn-primary">
                <i class="fa-solid fa-arrow-down"></i> Thêm xuống lưới
            </button>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-title"><i class="fa-solid fa-list" style="color:#64748b;"></i> DANH SÁCH MẶT HÀNG NHẬP</div>
    <div class="table-container">
        <table class="data-table" id="bangChiTiet">
            <thead>
                <tr>
                    <th class="text-center" style="width: 50px;">STT</th>
                    <th class="text-center">Mã vật tư</th>
                    <th class="text-center">Tên vật tư</th>
                    <th class="text-center">ĐVT</th>
                    <th class="text-center">Số lượng</th>
                    <th class="text-center">Đơn giá</th>
                    <th class="text-center">Thành tiền</th>
                    <th class="text-center" style="width: 60px;">Xóa</th>
                </tr>
            </thead>
            <input type="hidden" id="hdfPhieuXuatId" value="@Model.Id" />
            <tbody id="chiTietBody">
                @if (Model.ChiTietPhieuXuats != null && Model.ChiTietPhieuXuats.Any())
                {
                    int stt = 1;
                    foreach (var item in Model.ChiTietPhieuXuats)
                    {
                        <tr>
                            <td class="text-center">@(stt++)</td>

                            <td class="text-center td-mavat">
                                @item.VatTu?.MaVatTu
                            </td>

                            <td class="td-vattu" data-id="@(item.VatTuId)">
                                @item.VatTu?.TenVatTu
                            </td>

                            <td class="text-center">@item.VatTu?.DonViTinh</td>

                            <td type="number" class="text-center num-soluong" step="any" data-value="@item.SoLuong">
                                @item.SoLuong.ToString("N0")
                            </td>

                            <td type="number" class="text-center num-dongia" step="any" data-value="@item.DonGiaXuat">
                                @item.DonGiaXuat.ToString("N0") ₫
                            </td>

                            <td class="text-center num-thanhtien" data-value="@item.ThanhTien" style="font-weight:700; color:#e11d48;">
                                @item.ThanhTien.ToString("N0") ₫
                            </td>

                            <td class="text-center">
                                <button class="btn btn-danger btn-delete-row" data-id="@item.Id" style="padding:6px 10px;">
                                    <i class="fa fa-trash"></i>
                                </button>
                            </td>
                        </tr>

                    }
                }
                else
                {
                    <tr id="emptyRow">
                        <td colspan="8" class="text-center" style="color: #94a3b8; font-style: italic; padding: 30px;">
                            Chưa có vật tư nào trong phiếu. Vui lòng chọn vật tư và thêm xuống lưới!
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="summary-section">
        <div class="summary-box">
            <div class="summary-line">
                <span>Tổng số mặt hàng:</span>
                <span id="lblTongMatHang" style="font-weight: 600; color: #0f172a;">0</span>
            </div>
            <div class="summary-line">
                <span>Tổng số lượng:</span>
                <span id="lblTongSoLuong" style="font-weight: 600; color: #0f172a;">0</span>
            </div>
            <div class="summary-total">
                <span>TỔNG TIỀN:</span>
                <span id="lblTongTien">0 đ</span>
            </div>
        </div>
    </div>
</div>
<!-- Gọi file JS xử lý (ctXuat.js) đã được thiết kế sẵn -->
<script src="~/js/ctXuat.js" asp-append-version="true"></script>