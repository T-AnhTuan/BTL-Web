@model QuanLyVatTu.ViewModels.PhanQuyenVM
@{
    ViewData["Title"] = "Phân quyền người dùng";
}
<head>
    <link rel="stylesheet" href="~/css/phanquyen.css" asp-append-version="true">
</head>

<div class="page-header">
    <h1 class="page-title">Quản lý vai trò và Phân quyền</h1>
    <div style="display: flex; gap: 10px;">
        <button type="submit" form="frmPhanQuyen" class="btn btn-dark"><i class="fa-solid fa-floppy-disk"></i> Lưu cấu hình</button>
        <a href="@Url.Action("PhanQuyen", "QuanTri")" class="btn btn-outline">Hủy bỏ</a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<div class="permissions-container">
    <!-- CỘT TRÁI: Danh sách Vai Trò động từ DB -->
    <div class="roles-sidebar">
        <ul class="role-list">
            @foreach (var role in Model.DanhSachVaiTro)
            {
                // Thêm class active nếu vai trò này đang được chọn
                var activeClass = (role.Id == Model.VaiTroDangChon.Id) ? "active" : "";
                <li class="@activeClass">
                    <a href="@Url.Action("PhanQuyen", "QuanTri", new { vaiTroId = role.Id })" style="text-decoration:none; color:inherit; display:block;">
                        @role.TenVaiTro
                    </a>
                </li>
            }
        </ul>
        <button id="btnOpenRoleModal" class="btn-add-role"><i class="fa-solid fa-plus"></i> Thêm vai trò mới</button>
    </div>

    <!-- CỘT PHẢI: Ma trận quyền động -->
    <div class="matrix-content">
        <div class="info-alert">
            <i class="fa-solid fa-circle-info"></i>
            <span>Cấu hình phân quyền cho vai trò: <strong>@Model.VaiTroDangChon.TenVaiTro</strong></span>
        </div>

        <form id="frmPhanQuyen" asp-action="LuuPhanQuyen" method="post">
            <input type="hidden" name="VaiTroId" value="@Model.VaiTroDangChon.Id" />

            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width: 150px;">Mã Module</th>
                        <th>Tên Chức Năng</th>
                        <th style="width: 80px; text-align:center;">Xem</th>
                        <th style="width: 80px; text-align:center;">Thêm</th>
                        <th style="width: 80px; text-align:center;">Sửa</th>
                        <th style="width: 80px; text-align:center;">Xóa</th>
                        <th style="width: 100px; text-align:center;">Toàn quyền</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.VaiTroDangChon.PhanQuyens != null && Model.VaiTroDangChon.PhanQuyens.Any())
                    {
                        var listQuyen = Model.VaiTroDangChon.PhanQuyens.OrderBy(q => q.Id).ToList();
                        for (int i = 0; i < listQuyen.Count; i++)
                        {
                          
                            <tr>
                                <td>@listQuyen[i].MaChucNang</td>
                                <td>
                                    @listQuyen[i].TenChucNang
                                    <input type="hidden" name="PhanQuyens[@i].Id" value="@listQuyen[i].Id" />
                                </td>                               

                                <!-- Kỹ thuật binding Checkbox an toàn trong MVC -->
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input" name="PhanQuyens[@i].CoQuyenXem" value="true" @(listQuyen[i].CoQuyenXem ? "checked" : "") />
                                    <input type="hidden" name="PhanQuyens[@i].CoQuyenXem" value="false" />
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input" name="PhanQuyens[@i].CoQuyenThem" value="true" @(listQuyen[i].CoQuyenThem ? "checked" : "") />
                                    <input type="hidden" name="PhanQuyens[@i].CoQuyenThem" value="false" />
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input" name="PhanQuyens[@i].CoQuyenSua" value="true" @(listQuyen[i].CoQuyenSua ? "checked" : "") />
                                    <input type="hidden" name="PhanQuyens[@i].CoQuyenSua" value="false" />
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input" name="PhanQuyens[@i].CoQuyenXoa" value="true" @(listQuyen[i].CoQuyenXoa ? "checked" : "") />
                                    <input type="hidden" name="PhanQuyens[@i].CoQuyenXoa" value="false" />
                                </td>
                                <td class="text-center">
                                    <input type="checkbox" class="form-check-input chk-all-row" title="Chọn tất cả quyền cho chức năng này" />
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">Vai trò này chưa được khởi tạo danh sách chức năng.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </form>
    </div>
</div>

<!-- Modal Thêm Vai Trò (Giữ nguyên giao diện của bạn) -->
<div id="addRoleModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fa-solid fa-shield-halved" style="color:#1e293b; margin-right:8px;"></i> THÊM VAI TRÒ MỚI</h3>
            <button id="btnCloseRoleModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>
        <div class="modal-body">
            <div class="form-group">
                <label>Tên Vai Trò <span style="color:red">*</span></label>
                <input type="text" id="newRoleName" placeholder="Ví dụ: Giám đốc...">
            </div>
            <div class="form-group">
                <label>Mô tả</label>
                <input type="text" id="newRoleDesc" placeholder="Nhập mô tả...">
            </div>
        </div>
        <div class="modal-footer">
            <button id="btnCancelRole" class="btn btn-cancel">Hủy Bỏ</button>
            <button id="btnSaveRole" class="btn btn-dark"><i class="fa-solid fa-floppy-disk"></i> Lưu vai trò</button>
        </div>
    </div>
</div>

<script src="~/js/phanquyen.js" asp-append-version="true"></script>
