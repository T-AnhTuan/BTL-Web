@{
    ViewData["Title"] = "Dashboard";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true">

<h1 class="page-title">Bảng Điều Khiển Quản Lý Kho</h1>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon icon-orange"><i class="fa-solid fa-box-open"></i></div>
        <div class="stat-info">
            <div class="stat-title">Tổng loại vật tư <span class="badge-percent badge-neutral">0%</span></div>
            <div class="stat-value">0 <span style="font-size: 13px; font-weight: 500; color: #64748b;">mặt hàng</span></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon icon-green"><i class="fa-solid fa-sack-dollar"></i></div>
        <div class="stat-info">
            <div class="stat-title">Tổng giá trị Tồn kho <span class="badge-percent badge-neutral">0%</span></div>
            <div class="stat-value">0 VNĐ</div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon icon-blue"><i class="fa-solid fa-truck-ramp-box"></i></div>
        <div class="stat-info">
            <div class="stat-title">Phiếu Nhập Mới (Tuần) <span class="badge-percent badge-neutral">0%</span></div>
            <div class="stat-value">0 <span style="font-size: 13px; font-weight: 500; color: #64748b;">phiếu</span></div>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon icon-purple"><i class="fa-solid fa-right-from-bracket"></i></div>
        <div class="stat-info">
            <div class="stat-title">Phiếu Xuất Mới (Tuần) <span class="badge-percent badge-neutral">0%</span></div>
            <div class="stat-value">0 <span style="font-size: 13px; font-weight: 500; color: #64748b;">phiếu</span></div>
        </div>
    </div>
</div>

<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-header">Xu hướng Nhập/Xuất Hàng (30 ngày qua)</div>
        <canvas id="trendChart" height="100"></canvas>
    </div>

    <div class="chart-card">
        <div class="chart-header">Cơ cấu Tồn Kho theo Danh Mục</div>
        <canvas id="categoryChart" height="200"></canvas>
    </div>
</div>

<div class="tables-grid">
    <div class="table-card">
        <div class="chart-header">Cảnh báo Vật Tư Sắp Hết Hàng</div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Mã VT</th>
                    <th>Tên Vật Tư</th>
                    <th>Số Lượng</th>
                    <th>Định Mức</th>
                    <th class="text-center">Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>

    <div class="table-card">
        <div class="chart-header">Hoạt Động Kho Gần Đây</div>
        <table class="data-table">
            <thead>
                <tr>
                    <th>Thời Gian</th>
                    <th>Loại</th>
                    <th>Số Phiếu</th>
                    <th>Người Thực Hiện</th>
                    <th>Nội Dung</th>
                </tr>
            </thead>
            <tbody>
            </tbody>
        </table>
    </div>
</div>

<script src="~/js/site.js" asp-append-version="true">
    
</script>