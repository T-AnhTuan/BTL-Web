@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ thống đang bảo trì - Quản Lý Vật Tư</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
            body {
                background-color: #f8f9fa; 
                height: 100vh; 
                display: flex; 
                align-items: center; 
                justify-content: center; 
                text-align: center; 
            }
            .icon-baotri {
                font-size: 80px;
                color: #dc3545; 
                margin-bottom: 20px;
                animation: xoay 4s linear infinite; 
            }
            @@keyframes xoay {
                100% { transform: rotate(360deg); }
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="row">
            <div class="col-md-12">
                <i class="fas fa-cog icon-baotri"></i>
                <h1 class="display-5 fw-bold text-dark">Hệ thống đang bảo trì hoặc gặp sự cố</h1>
                <p class="lead text-muted mt-3">
                    Xin lỗi vì sự bất tiện này. Chúng tôi đang nỗ lực khắc phục sự cố hoặc nâng cấp hệ thống.<br />
                    Vui lòng quay lại sau ít phút nhé!
                </p>
                <div class="mt-4">
                    <a href="/" class="btn btn-primary btn-lg shadow-sm">
                        <i class="fas fa-home me-2"></i> Thử quay lại Trang chủ
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>