@using QuanLyVatTu.Models
@model IEnumerable<NhaCungCap>
@{
    ViewData["Title"] = "Quản Lý Nhà Cung Cấp";
}
<link rel="stylesheet" href="~/css/ncc.css" asp-append-version="true"/>

<div class="page-header">
    <h1 class="page-title">Quản lý Nhà cung cấp</h1>
</div>

<div class="filter-section">
    <div class="search-input-wrapper">
        <i class="fa-solid fa-magnifying-glass"></i>
        <input type="text" class="search-input" placeholder="Tìm kiếm nhà cung cấp...">
    </div>

    <button id="btnOpenModal" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Thêm Mới Nhà Cung Cấp</button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>STT</th>
                <th>Mã NCC</th>
                <th>Tên đơn vị</th>
                <th>Địa chỉ</th>
                <th>Hotline</th>
                <th>Email</th>
                <th class="text-center">Trạng thái</th>
                <th class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int stt = 1;
                foreach (var item in Model)
                {
                    <tr data-id="@item.Id">
                        <td>@(stt++)</td>
                        <td>@item.MaNCC</td>
                        <td style="font-weight:500;">@item.TenNhaCungCap</td>
                        <td>@item.DiaChi</td>
                        <td>@item.SoDienThoai</td>
                        <td>@item.Email</td>
                        <td class="text-center">
                            @if ((int)item.TrangThai == 1)
                            {
                                <span>Hoạt động</span>
                            }
                            else
                            {
                                <span>Tạm ngừng</span>
                            }
                        </td>
                        <td class="text-center" style="justify-content: center; gap: 10px; display: flex;">
                            <button class="btn btn-sm btn-primary btn-edit" data-id="@item.Id" style="background: green; color: white;"><i class="fa-solid fa-pen-to-square"></i> Sửa</button>
                            <button class="btn btn-sm btn-danger btn-delete" data-id="@item.Id" style="background: red; color: white;"><i class="fa-solid fa-trash"></i> Xóa</button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="text-center">Không có nhà cung cấp để hiển thị.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="addSupplierModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3><i class="fa-solid fa-industry" style="color:#2563eb; margin-right:8px;"></i> Thêm Mới Nhà Cung Cấp</h3>
            <button id="btnCloseModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="inputId" value="0">

            <div class="input-row">
                <div class="form-group">
                    <label>Mã NCC <span style="color:red">*</span></label>
                    <input type="text" id="inputMaNCC" name="MaNCC" placeholder="VD: NCC001...">
                </div>
                <div class="form-group">
                    <label>Trạng Thái</label>
                    <select id="selectTrangThai" name="TrangThai">
                        <option value="1">Hoạt động</option>
                        <option value="0">Tạm ngừng</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label>Tên Nhà Cung Cấp <span style="color:red">*</span></label>
                <input type="text" id="inputTen" name="TenNhaCungCap" placeholder="Nhập tên công ty / cá nhân...">
            </div>

            <div class="form-group">
                <label>Địa Chỉ</label>
                <input type="text" id="inputDiaChi" name="DiaChi" placeholder="Nhập địa chỉ chi tiết...">
            </div>

            <div class="input-row">
                <div class="form-group">
                    <label>Số Điện Thoại</label>
                    <input type="text" id="inputSDT" name="SoDienThoai" placeholder="VD: 0905 123 456">
                </div>
                <div class="form-group">
                    <label>Email</label>
                    <input type="email" id="inputEmail" name="Email" placeholder="VD: contact@company.com">
                </div>
            </div>
        </div>

        <div class="modal-footer">
            <button id="btnCancel" class="btn btn-cancel">Hủy Bỏ</button>
            <button id="btnSave" class="btn btn-primary"><i class="fa-solid fa-floppy-disk"></i> Lưu Thay Đổi</button>
        </div>
    </div>
</div>

<script src="~/js/ncc.js" asp-append-version="true"></script>
