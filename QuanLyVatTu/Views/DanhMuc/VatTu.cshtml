@using QuanLyVatTu.Models
@model IEnumerable<DanhMucVatTu>
@{
    ViewData["Title"] = "Danh Sách Danh Mục Vật Tư";
}

<link rel="stylesheet" href="~/css/danhmucvattu.css" asp-append-version="true">

<div class="page-header">
    <h1 class="page-title">DANH MỤC VẬT TƯ</h1>
</div>

<div class="filter-section">
    <input type="text" class="search-input" placeholder="Tìm kiếm theo tên hoặc mã danh mục...">

    <div style="display:flex; align-items: center; gap: 10px;">
        <span style="font-size:14px; color:#475569; font-weight:500;">Trạng thái</span>
        <select class="status-select">
            <option value="">Tất cả</option>
            <option value="1">Hoạt động</option>
            <option value="0">Tạm ngừng</option>
        </select>
    </div>

    <button id="btnOpenModal" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Thêm Danh Mục Mới</button>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th style="width: 40px;"><input type="checkbox"></th>
                <th>STT</th>
                <th>Mã Danh Mục</th>
                <th>Tên Danh Mục</th>
                <th>Mô Tả</th>
                <th>Người Tạo</th>
                <th>Ngày Tạo</th>
                <th class="text-center">Trạng Thái</th>
                <th class="text-center">Hành Động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                int stt = 1;
                foreach (var item in Model)
                {
                    <tr>
                        <td><input type="checkbox"></td>
                        <td>@(stt++)</td>
                        <td>@item.MaDanhMuc</td>
                        <td style="font-weight: 500;">@item.TenDanhMuc</td>
                        <td>@item.MoTa</td>
                        <td>@item.NguoiTao</td>
                        <td>@item.NgayTao.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            @if ((int)item.TrangThai==1)
                            {
                                <span>Hoạt động</span>
                            }
                            else
                            {
                                <span>Tạm ngừng</span>
                            }
                        </td>
                        <td class="text-center">
                            <button class="action-btn edit-btn"><i class="fa-solid fa-pen-to-square"></i></button>
                            <button class="action-btn delete-btn"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10" class="text-center">Không có danh mục nào để hiển thị.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="addCategoryModal" class="modal-overlay">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Thêm Danh Mục Mới</h3>
            <button id="btnCloseModal" class="close-btn"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="modal-body">
            <input type="hidden" id="inputId" value="0">

            <div class="form-group">
                <label>Tên Danh Mục <span style="color:red">*</span></label>
                <input type="text" placeholder="VD: Vật tư xây dựng, Công cụ dụng cụ...">
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <textarea rows="3" placeholder="Ghi chú thêm về danh mục này..."></textarea>
            </div>

            <div class="form-group">
                <label>Trạng thái</label>
                <select>
                    <option value="active">Hoạt động</option>
                    <option value="inactive">Tạm ngừng</option>
                </select>
            </div>
        </div>

        <div class="modal-footer">
            <button id="btnCancel" class="btn btn-cancel">Hủy</button>
            <button id="btnSave" class="btn btn-primary">Lưu danh mục</button>
        </div>
    </div>
</div>

<script>
    const catModal = document.getElementById('addCategoryModal');
    const btnOpenCat = document.getElementById('btnOpenModal');
    const btnCloseCat = document.getElementById('btnCloseModal');
    const btnCancelCat = document.getElementById('btnCancel');
    const btnSaveCat = document.getElementById('btnSave');

    btnOpenCat.onclick = () => catModal.classList.add('show');

    const closeCatModal = () => catModal.classList.remove('show');
    btnCloseCat.onclick = closeCatModal;
    btnCancelCat.onclick = closeCatModal;

    window.onclick = (e) => { if (e.target == catModal) closeCatModal(); }

    btnSaveCat.onclick = () => {
        alert("Giao diện form đã hoàn tất! Chờ Back-end xử lý submit dữ liệu.");
        closeCatModal();
    }
</script>